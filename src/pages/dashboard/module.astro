---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Materi Pembelajaran" activePage="modules" role="learner">

  <!-- Loader -->
  <div id="view-loader" class="loader-state">
    <div class="loader-spinner"></div>
    <p>Memuat materi...</p>
  </div>

  <!-- Main Content (hidden until loaded) -->
  <div class="module-view" id="module-view" style="display:none;">

    <!-- Back link -->
    <a href="/dashboard" class="back-btn">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
      </svg>
      Kembali ke Modul
    </a>

    <!-- Module Header -->
    <div class="mod-header">
      <div class="mod-meta">
        <span class="mod-category-badge">📖 Materi Belajar</span>
        <h1 class="mod-title" id="mod-title">Judul Modul</h1>
        <p class="mod-desc" id="mod-desc">Deskripsi modul akan muncul di sini.</p>
      </div>
    </div>

    <!-- Two-column layout -->
    <div class="mod-body">

      <!-- LEFT: Video + Description -->
      <div class="left-col">
        <!-- Video Player -->
        <div class="video-wrap">
          <div class="video-placeholder" id="video-placeholder">
            <svg width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <p>Video tidak tersedia</p>
          </div>
          <iframe id="vid-frame" class="vid-frame" style="display:none;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>

        <!-- Module info card -->
        <div class="info-card">
          <div class="info-item">
            <div class="info-icon">⏱️</div>
            <div>
              <span class="info-label">Durasi</span>
              <span class="info-val">~15 menit</span>
            </div>
          </div>
          <div class="info-divider"></div>
          <div class="info-item">
            <div class="info-icon">📊</div>
            <div>
              <span class="info-label">Tingkat</span>
              <span class="info-val">Pemula</span>
            </div>
          </div>
          <div class="info-divider"></div>
          <div class="info-item">
            <div class="info-icon">🏆</div>
            <div>
              <span class="info-label">Poin Kuis</span>
              <span class="info-val">100 pts</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Actions + Tips -->
      <div class="right-col">
        <!-- Quiz CTA Card -->
        <div class="quiz-card">
          <div class="quiz-card-header">
            <div class="quiz-icon">🎯</div>
            <div>
              <h3 class="quiz-title">Kuis Tersedia!</h3>
              <p class="quiz-sub">Uji pemahamanmu dan kumpulkan poin.</p>
            </div>
          </div>

          <div class="quiz-meta">
            <div class="qm-item">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>
              </svg>
              10 Pertanyaan
            </div>
            <div class="qm-item">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              15 Menit
            </div>
            <div class="qm-item">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
              </svg>
              +100 Poin
            </div>
          </div>

          <button class="btn-quiz" id="btn-start-quiz">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347c-.75.412-1.667-.13-1.667-.986V5.653z"/>
            </svg>
            Mulai Kuis Sekarang
          </button>
        </div>

        <!-- Tips Card -->
        <div class="tips-card">
          <h4 class="tips-title">💡 Tips Belajar Efektif</h4>
          <ul class="tips-list">
            <li>Tonton video hingga selesai sebelum mengerjakan kuis</li>
            <li>Catat poin-poin penting selama menonton</li>
            <li>Ulangi bagian yang belum dipahami</li>
            <li>Kerjakan kuis saat sudah merasa siap</li>
          </ul>
        </div>

        <!-- Navigation Card -->
        <div class="nav-card">
          <h4 class="nav-card-title">Navigasi Modul</h4>
          <div class="nav-btns">
            <button class="nav-btn" disabled>
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
              </svg>
              Sebelumnya
            </button>
            <button class="nav-btn">
              Selanjutnya
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
              </svg>
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  /* Loader */
  .loader-state {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 14px; padding: 80px 20px;
    color: rgba(255,255,255,0.3); font-size: 13px;
  }
  .loader-spinner {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 3px solid rgba(99,102,241,0.15);
    border-top-color: #6366f1;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Back btn */
  .back-btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.35); text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .back-btn:hover { color: #818cf8; }

  /* Module Header */
  .mod-header { margin-bottom: 28px; }
  .mod-category-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
    color: #818cf8; background: rgba(99,102,241,0.12);
    border: 1px solid rgba(99,102,241,0.25);
    padding: 4px 12px; border-radius: 99px; margin-bottom: 14px;
  }
  .mod-title {
    font-size: 28px; font-weight: 900; color: #f1f5f9;
    letter-spacing: -0.5px; line-height: 1.3; margin-bottom: 10px;
  }
  .mod-desc {
    font-size: 14px; color: rgba(255,255,255,0.45);
    line-height: 1.7; max-width: 700px;
  }

  /* Body Layout */
  .mod-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 900px) { .mod-body { grid-template-columns: 1fr; } }

  /* Video */
  .video-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    background: #0a0e1a;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    position: relative;
    margin-bottom: 16px;
  }
  .video-placeholder {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 12px;
    color: rgba(255,255,255,0.12);
    font-size: 13px;
  }
  .vid-frame { width: 100%; height: 100%; border: none; }

  /* Info card */
  .info-card {
    background: #161d2e;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 16px 20px;
    display: flex; align-items: center;
    gap: 0;
  }
  .info-item { display: flex; align-items: center; gap: 12px; flex: 1; }
  .info-icon { font-size: 20px; }
  .info-label { display: block; font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.5px; }
  .info-val { display: block; font-size: 14px; font-weight: 700; color: #f1f5f9; margin-top: 2px; }
  .info-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.05); margin: 0 8px; }

  /* Right column */
  .right-col { display: flex; flex-direction: column; gap: 16px; }

  /* Quiz Card */
  .quiz-card {
    background: linear-gradient(135deg, #1e1b4b 0%, #1e1040 100%);
    border: 1px solid rgba(99,102,241,0.25);
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 8px 32px rgba(99,102,241,0.1);
  }
  .quiz-card-header { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px; }
  .quiz-icon {
    font-size: 24px; width: 52px; height: 52px;
    background: rgba(255,255,255,0.08);
    border-radius: 14px; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .quiz-title { font-size: 16px; font-weight: 800; color: #f1f5f9; margin-bottom: 4px; }
  .quiz-sub { font-size: 12px; color: rgba(255,255,255,0.45); }

  .quiz-meta { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .qm-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.5);
  }
  .qm-item svg { color: rgba(255,255,255,0.3); flex-shrink: 0; }

  .btn-quiz {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 13px 20px; border-radius: 12px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff; font-size: 14px; font-weight: 800;
    border: none; cursor: pointer; font-family: 'Inter', sans-serif;
    box-shadow: 0 6px 20px rgba(99,102,241,0.4);
    transition: all 0.25s;
  }
  .btn-quiz:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(99,102,241,0.5); filter: brightness(1.08); }

  /* Tips Card */
  .tips-card {
    background: #161d2e;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 20px;
  }
  .tips-title { font-size: 13px; font-weight: 700; color: #f1f5f9; margin-bottom: 14px; }
  .tips-list { list-style: none; display: flex; flex-direction: column; gap: 8px; padding: 0; }
  .tips-list li {
    font-size: 12px; color: rgba(255,255,255,0.45);
    display: flex; align-items: flex-start; gap: 8px;
    line-height: 1.5;
  }
  .tips-list li::before {
    content: '→';
    color: #6366f1; font-weight: 700; flex-shrink: 0; font-size: 11px; margin-top: 1px;
  }

  /* Navigation */
  .nav-card {
    background: #161d2e;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px; padding: 16px;
  }
  .nav-card-title { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
  .nav-btns { display: flex; gap: 8px; }
  .nav-btn {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px;
    padding: 9px 14px; border-radius: 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.5); font-size: 12px; font-weight: 600;
    cursor: pointer; font-family: 'Inter', sans-serif;
    transition: all 0.15s;
  }
  .nav-btn:hover:not(:disabled) { background: rgba(99,102,241,0.1); color: #818cf8; border-color: rgba(99,102,241,0.25); }
  .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }
</style>

<script>
  import { supabase } from '../../lib/supabase';

  function extractYoutubeId(url: string) {
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
  }

  window.addEventListener('dashboard:ready', async () => {
    const urlParams = new URLSearchParams(window.location.search);
    const modId = urlParams.get('id');
    const loader = document.getElementById('view-loader')!;

    if (!modId) {
      loader.innerHTML = '<p style="color:#f87171;font-size:13px;">❌ ID modul tidak ditemukan.</p>';
      return;
    }

    const { data: mod, error } = await supabase.from('modules').select('*').eq('id', modId).single();

    if (error || !mod) {
      loader.innerHTML = '<p style="color:#f87171;font-size:13px;">❌ Modul tidak ditemukan atau gagal dimuat.</p>';
      return;
    }

    // Populate
    document.getElementById('mod-title')!.textContent = mod.title;
    document.getElementById('mod-desc')!.textContent = mod.description || 'Tidak ada deskripsi untuk modul ini.';
    document.title = `${mod.title} — BrainUp`;

    // Video
    if (mod.video_url) {
      const vidId = extractYoutubeId(mod.video_url);
      const iframe = document.getElementById('vid-frame') as HTMLIFrameElement;
      if (vidId) {
        iframe.src = `https://www.youtube.com/embed/${vidId}?rel=0&modestbranding=1`;
        iframe.style.display = 'block';
        document.getElementById('video-placeholder')!.style.display = 'none';
      } else {
        document.getElementById('video-placeholder')!.innerHTML = `
          <video controls src="${mod.video_url}" style="width:100%;height:100%;background:#000;"></video>`;
      }
    }

    // Show view
    loader.style.display = 'none';
    document.getElementById('module-view')!.style.display = 'block';

    // Quiz button
    document.getElementById('btn-start-quiz')!.addEventListener('click', () => {
      alert(`Sistem kuis segera hadir! Modul ID: ${mod.id}`);
    });
  });
</script>
