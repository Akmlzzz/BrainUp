---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Admin Dashboard" activePage="dashboard" role="admin">

  <!-- Page Header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Admin Dashboard</h1>
      <p class="page-sub">Pantau dan kelola seluruh konten platform BrainUp.</p>
    </div>
    <button class="btn-primary" id="btn-add-modul">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      Tambah Modul
    </button>
  </div>

  <!-- Stat Cards -->
  <div class="stat-grid">
    <div class="stat-card card-indigo">
      <div class="stat-icon-wrap">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
        </svg>
      </div>
      <div class="stat-data">
        <span class="stat-label">Total Modul</span>
        <span class="stat-value" id="stat-modul">—</span>
        <span class="stat-change pos">Modul aktif</span>
      </div>
    </div>
    <div class="stat-card card-cyan">
      <div class="stat-icon-wrap">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
      </div>
      <div class="stat-data">
        <span class="stat-label">Total Pengguna</span>
        <span class="stat-value" id="stat-users">—</span>
        <span class="stat-change pos">Terdaftar</span>
      </div>
    </div>
    <div class="stat-card card-emerald">
      <div class="stat-icon-wrap">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="stat-data">
        <span class="stat-label">Modul Diselesaikan</span>
        <span class="stat-value" id="stat-done">—</span>
        <span class="stat-change pos">Kali dikerjakan</span>
      </div>
    </div>
    <div class="stat-card card-amber">
      <div class="stat-icon-wrap">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
        </svg>
      </div>
      <div class="stat-data">
        <span class="stat-label">Total Poin Diberikan</span>
        <span class="stat-value" id="stat-poin">—</span>
        <span class="stat-change neu">Platform-wide</span>
      </div>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="main-grid">

    <!-- Modules Table Panel -->
    <div class="table-panel">
      <div class="panel-header">
        <div class="panel-header-left">
          <h3 class="panel-title">Daftar Modul</h3>
          <span class="item-count" id="modul-count">0 modul</span>
        </div>
        <div class="panel-actions">
          <div class="search-box">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
            </svg>
            <input type="text" id="table-search" placeholder="Cari modul..."/>
          </div>
        </div>
      </div>

      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width:44px;">#</th>
              <th>Judul Modul</th>
              <th>Deskripsi</th>
              <th>Video</th>
              <th style="width:100px;text-align:right;">Aksi</th>
            </tr>
          </thead>
          <tbody id="modules-body">
            <tr><td colspan="5" class="table-loading">
              <div class="loading-spinner"></div>
              Memuat data...
            </td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Right column: Quick Stats + Activity -->
    <div class="right-panel">

      <!-- Quick Actions -->
      <div class="quick-card">
        <h4 class="quick-title">Aksi Cepat</h4>
        <div class="quick-list">
          <button class="quick-item" id="qa-tambah-modul">
            <div class="qi-icon qi-blue">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
              </svg>
            </div>
            <div class="qi-info">
              <span class="qi-label">Tambah Modul Baru</span>
              <span class="qi-sub">Buat konten pembelajaran</span>
            </div>
            <svg class="qi-arrow" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </button>

          <a href="/dashboard" class="quick-item" target="_blank">
            <div class="qi-icon qi-green">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div class="qi-info">
              <span class="qi-label">Preview Learner View</span>
              <span class="qi-sub">Lihat tampilan pelajar</span>
            </div>
            <svg class="qi-arrow" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </a>

          <div class="quick-item" style="opacity:0.5;cursor:not-allowed;">
            <div class="qi-icon qi-purple">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
              </svg>
            </div>
            <div class="qi-info">
              <span class="qi-label">Kelola Pengguna</span>
              <span class="qi-sub">Segera hadir</span>
            </div>
            <span class="qi-badge">Soon</span>
          </div>
        </div>
      </div>

      <!-- System Status -->
      <div class="quick-card">
        <h4 class="quick-title">Status Sistem</h4>
        <div class="status-list">
          <div class="status-item">
            <span class="status-dot dot-green"></span>
            <span class="status-text">Database Online</span>
            <span class="status-val ok">OK</span>
          </div>
          <div class="status-item">
            <span class="status-dot dot-green"></span>
            <span class="status-text">Supabase Auth</span>
            <span class="status-val ok">OK</span>
          </div>
          <div class="status-item">
            <span class="status-dot dot-green"></span>
            <span class="status-text">Storage</span>
            <span class="status-val ok">OK</span>
          </div>
          <div class="status-item">
            <span class="status-dot dot-yellow"></span>
            <span class="status-text">Quiz Engine (FastAPI)</span>
            <span class="status-val warn">Dev</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay hidden" id="modal-form">
    <div class="modal-content">
      <div class="modal-head">
        <div class="modal-icon">✏️</div>
        <div>
          <h3 class="modal-title" id="modal-title">Tambah Modul</h3>
          <p class="modal-sub">Isi detail modul pembelajaran di bawah ini.</p>
        </div>
        <button class="modal-close" id="btn-modal-close">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <form id="modul-form">
        <input type="hidden" id="entry-id"/>
        <div class="form-group">
          <label for="title">Judul Modul <span class="req">*</span></label>
          <input type="text" id="title" required placeholder="Contoh: Dasar-Dasar Aljabar"/>
        </div>
        <div class="form-group">
          <label for="description">Deskripsi Singkat</label>
          <textarea id="description" rows="3" placeholder="Jelaskan isi dan tujuan modul ini..."></textarea>
        </div>
        <div class="form-group">
          <label for="video_url">URL Video (YouTube / MP4)</label>
          <input type="url" id="video_url" placeholder="https://youtube.com/watch?v=..."/>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-ghost" id="btn-cancel">Batal</button>
          <button type="submit" class="btn-save" id="btn-save">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            Simpan Modul
          </button>
        </div>
      </form>
    </div>
  </div>

</DashboardLayout>

<style>
  /* Page Header */
  .page-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 28px; flex-wrap: wrap; gap: 12px;
  }
  .page-title { font-size: 22px; font-weight: 800; color: #f1f5f9; letter-spacing: -0.3px; margin-bottom: 4px; }
  .page-sub { font-size: 13px; color: rgba(255,255,255,0.4); }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 10px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: #fff; font-size: 13px; font-weight: 700;
    border: none; cursor: pointer; font-family: 'Montserrat', sans-serif;
    box-shadow: 0 4px 16px rgba(37,99,235,0.35);
    transition: all 0.2s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,99,235,0.45); filter: brightness(1.08); }

  /* Stat Grid */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 1100px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }

  .stat-card {
    background: #071428;
    border: 1px solid rgba(59,130,246,0.08);
    border-radius: 16px; padding: 20px;
    display: flex; align-items: flex-start; gap: 14px;
    position: relative; overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .stat-card::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 2px; border-radius: 16px 16px 0 0;
  }
  .stat-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
  .card-indigo::after { background: linear-gradient(90deg, #2563eb, #06b6d4); }
  .card-cyan::after   { background: linear-gradient(90deg, #06b6d4, #67e8f9); }
  .card-emerald::after{ background: linear-gradient(90deg, #10b981, #34d399); }
  .card-amber::after  { background: linear-gradient(90deg, #f59e0b, #fbbf24); }

  .stat-icon-wrap {
    width: 44px; height: 44px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .card-indigo .stat-icon-wrap { background: rgba(99,102,241,0.15); color: #818cf8; }
  .card-cyan   .stat-icon-wrap { background: rgba(6,182,212,0.15);  color: #67e8f9; }
  .card-emerald.stat-icon-wrap { background: rgba(16,185,129,0.15); color: #34d399; }
  .card-amber  .stat-icon-wrap { background: rgba(245,158,11,0.15); color: #fbbf24; }
  /* Fix: target stat-icon-wrap inside each card */
  .card-emerald .stat-icon-wrap { background: rgba(16,185,129,0.15); color: #34d399; }
  .card-amber .stat-icon-wrap   { background: rgba(245,158,11,0.15); color: #fbbf24; }

  .stat-data { display: flex; flex-direction: column; gap: 2px; }
  .stat-label { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.6px; }
  .stat-value { font-size: 28px; font-weight: 800; color: #f1f5f9; letter-spacing: -0.5px; line-height: 1; margin: 4px 0 2px; }
  .stat-change { font-size: 11px; font-weight: 500; }
  .stat-change.pos { color: #34d399; }
  .stat-change.neu { color: rgba(255,255,255,0.3); }

  /* Main Grid */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 20px;
    align-items: start;
  }
  @media (max-width: 1024px) { .main-grid { grid-template-columns: 1fr; } }

  /* Table Panel */
  .table-panel {
    background: #071428;
    border: 1px solid rgba(59,130,246,0.08);
    border-radius: 20px;
    overflow: hidden;
  }
  .panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid rgba(59,130,246,0.06);
    gap: 12px; flex-wrap: wrap;
  }
  .panel-header-left { display: flex; align-items: center; gap: 10px; }
  .panel-title { font-size: 14px; font-weight: 700; color: #e8f4ff; }
  .item-count {
    font-size: 11px; padding: 2px 8px; border-radius: 99px;
    background: rgba(37,99,235,0.12); color: #93c5fd;
    border: 1px solid rgba(59,130,246,0.22); font-weight: 600;
  }
  .panel-actions { display: flex; align-items: center; gap: 10px; }
  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: rgba(37,99,235,0.06);
    border: 1px solid rgba(59,130,246,0.14);
    border-radius: 8px; padding: 7px 12px;
    color: rgba(255,255,255,0.30);
  }
  .search-box input {
    background: transparent; border: none; outline: none;
    color: #e8f4ff; font-size: 13px; font-family: 'Montserrat', sans-serif; width: 150px;
  }
  .search-box input::placeholder { color: rgba(255,255,255,0.22); }

  .table-wrap { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: separate; border-spacing: 0; text-align: left; }
  .data-table th {
    font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.3);
    text-transform: uppercase; letter-spacing: 0.6px;
    padding: 12px 20px; background: rgba(0,0,0,0.2);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  :global(.data-table td) {
    font-size: 13px; padding: 14px 20px;
    border-bottom: 1px solid rgba(59,130,246,0.05);
    color: #c7d9f0; vertical-align: middle;
  }
  :global(.data-table tbody tr:last-child td) { border-bottom: none; }
  :global(.data-table tbody tr:hover td) { background: rgba(37,99,235,0.05); }

  .table-loading {
    text-align: center; padding: 48px 20px !important;
    color: rgba(255,255,255,0.25) !important;
    font-size: 13px;
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .loading-spinner {
    width: 20px; height: 20px;
    border-radius: 50%;
    border: 2px solid rgba(99,102,241,0.15);
    border-top-color: #6366f1;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  :global(.row-num) { font-size: 12px; color: rgba(255,255,255,0.2); font-weight: 500; }
  :global(.row-title) { font-weight: 700; color: #f1f5f9 !important; }
  :global(.row-desc) { color: rgba(255,255,255,0.35) !important; font-size: 12px !important; max-width: 280px; }
  :global(.vid-link) {
    display: inline-flex; align-items: center; gap: 5px;
    color: #60a5fa; font-size: 12px; text-decoration: none; font-weight: 600;
  }
  :global(.vid-link:hover) { color: #93c5fd; }
  :global(.no-video) { color: rgba(255,255,255,0.2) !important; font-size: 12px !important; }
  :global(.action-btns) { display: flex; gap: 6px; justify-content: flex-end; }
  :global(.btn-icon) {
    width: 30px; height: 30px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    background: transparent; color: rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.06);
    cursor: pointer; transition: all 0.15s;
  }
  :global(.btn-icon svg) { width: 14px; height: 14px; }
  :global(.btn-icon.edit:hover) { background: rgba(37,99,235,0.12); color: #60a5fa; border-color: rgba(59,130,246,0.25); }
  :global(.btn-icon.delete:hover) { background: rgba(239,68,68,0.10); color: #fca5a5; border-color: rgba(239,68,68,0.20); }
  :global(.empty-row td) { text-align: center; padding: 56px !important; color: rgba(255,255,255,0.2) !important; font-size: 13px !important; }

  /* Right Panel */
  .right-panel { display: flex; flex-direction: column; gap: 16px; }

  .quick-card {
    background: #071428;
    border: 1px solid rgba(59,130,246,0.08);
    border-radius: 16px;
    overflow: hidden;
  }
  .quick-title {
    font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.28);
    text-transform: uppercase; letter-spacing: 0.7px;
    padding: 16px 20px 12px;
    border-bottom: 1px solid rgba(59,130,246,0.06);
  }
  .quick-list { padding: 10px; display: flex; flex-direction: column; gap: 4px; }
  .quick-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 10px; border-radius: 10px;
    background: transparent; border: none; cursor: pointer;
    font-family: 'Inter', sans-serif;
    text-decoration: none;
    transition: background 0.15s;
    width: 100%;
  }
  .quick-item:hover { background: rgba(255,255,255,0.03); }
  .qi-icon {
    width: 34px; height: 34px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .qi-blue   { background: rgba(37,99,235,0.12); color: #60a5fa; }
  .qi-green  { background: rgba(16,185,129,0.12); color: #34d399; }
  .qi-purple { background: rgba(6,182,212,0.12);  color: #67e8f9; }
  .qi-info { flex: 1; text-align: left; }
  .qi-label { display: block; font-size: 13px; font-weight: 600; color: #e2e8f0; }
  .qi-sub { display: block; font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 1px; }
  .qi-arrow { color: rgba(255,255,255,0.2); transition: transform 0.2s; }
  .quick-item:hover .qi-arrow { transform: translateX(3px); color: rgba(255,255,255,0.5); }
  .qi-badge {
    font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 99px;
    background: rgba(245,158,11,0.12); color: #fbbf24;
    border: 1px solid rgba(245,158,11,0.2);
  }

  /* Status */
  .status-list { padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; }
  .status-item { display: flex; align-items: center; gap: 10px; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .dot-green { background: #34d399; box-shadow: 0 0 6px rgba(52,211,153,0.5); }
  .dot-yellow { background: #fbbf24; box-shadow: 0 0 6px rgba(251,191,36,0.4); animation: pulse 2s infinite; }
  .dot-red { background: #f87171; box-shadow: 0 0 6px rgba(248,113,113,0.5); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .status-text { flex: 1; font-size: 12px; color: rgba(255,255,255,0.5); }
  .status-val { font-size: 11px; font-weight: 700; }
  .status-val.ok { color: #34d399; }
  .status-val.warn { color: #fbbf24; }
  .status-val.err { color: #f87171; }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(4,13,30,0.85);
    backdrop-filter: blur(12px);
    display: flex; align-items: center; justify-content: center;
    z-index: 999; padding: 20px;
  }
  .modal-overlay.hidden { display: none !important; }
  .modal-content {
    background: #071428;
    border: 1px solid rgba(59,130,246,0.18);
    border-radius: 24px;
    padding: 28px;
    width: 100%; max-width: 480px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    animation: slideUp 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .modal-head {
    display: flex; align-items: flex-start; gap: 14px;
    margin-bottom: 24px;
  }
  .modal-icon {
    font-size: 24px; width: 48px; height: 48px;
    background: rgba(37,99,235,0.12); border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .modal-title { font-size: 18px; font-weight: 800; color: #e8f4ff; margin-bottom: 2px; }
  .modal-sub { font-size: 12px; color: rgba(255,255,255,0.32); }
  .modal-close {
    width: 32px; height: 32px; border-radius: 8px; margin-left: auto;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.15s;
    display: flex; align-items: center; justify-content: center;
  }
  .modal-close:hover { background: rgba(239,68,68,0.1); color: #f87171; }

  .form-group { margin-bottom: 16px; }
  label { display: block; font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.4); margin-bottom: 7px; text-transform: uppercase; letter-spacing: 0.5px; }
  .req { color: #f87171; }
  input, textarea {
    width: 100%;
    background: rgba(37,99,235,0.04);
    border: 1px solid rgba(59,130,246,0.12);
    border-radius: 10px; padding: 11px 14px;
    color: #e8f4ff; font-family: 'Montserrat', sans-serif; font-size: 13px;
    transition: border-color 0.2s;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: rgba(37,99,235,0.50);
    background: rgba(37,99,235,0.06);
  }
  textarea { resize: vertical; min-height: 80px; }

  .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 24px; }
  .btn-ghost {
    padding: 10px 18px; border-radius: 10px;
    background: rgba(59,130,246,0.05);
    border: 1px solid rgba(59,130,246,0.10);
    color: rgba(255,255,255,0.55); font-size: 13px; font-weight: 600;
    cursor: pointer; font-family: 'Montserrat', sans-serif;
    transition: all 0.15s;
  }
  .btn-ghost:hover { background: rgba(59,130,246,0.10); color: #e8f4ff; }
  .btn-save {
    display: flex; align-items: center; gap: 7px;
    padding: 10px 20px; border-radius: 10px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: #fff; font-size: 13px; font-weight: 700;
    border: none; cursor: pointer; font-family: 'Montserrat', sans-serif;
    box-shadow: 0 4px 14px rgba(37,99,235,0.35);
    transition: all 0.2s;
  }
  .btn-save:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .btn-save:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
</style>

<script>
  import { supabase } from '../../../lib/supabase';

  let modules: any[] = [];
  const tbody = document.getElementById('modules-body')!;
  const modal = document.getElementById('modal-form')!;
  const form = document.getElementById('modul-form') as HTMLFormElement;
  const searchInput = document.getElementById('table-search') as HTMLInputElement;

  async function loadAdminData() {
    const { data, error } = await supabase.from('modules').select('*').order('created_at', { ascending: false });
    if (error) { console.error(error); return; }
    modules = data || [];

    // Update stats
    document.getElementById('stat-modul')!.textContent = String(modules.length);
    document.getElementById('stat-users')!.textContent = '—';
    document.getElementById('stat-done')!.textContent  = String(modules.length * 3); // mock
    document.getElementById('stat-poin')!.textContent  = String(modules.length * 300); // mock
    document.getElementById('modul-count')!.textContent = `${modules.length} modul`;

    renderTable(modules);
  }

  function renderTable(data: any[]) {
    if (data.length === 0) {
      tbody.innerHTML = `
        <tr class="empty-row">
          <td colspan="5">
            <div style="display:flex;flex-direction:column;align-items:center;gap:10px;">
              <span style="font-size:32px;">📭</span>
              <span>Belum ada modul. Klik "Tambah Modul" untuk mulai.</span>
            </div>
          </td>
        </tr>`;
      return;
    }

    tbody.innerHTML = '';
    data.forEach((m, i) => {
      const tr = document.createElement('tr');
      const hasVideo = m.video_url && m.video_url.trim() !== '';
      tr.innerHTML = `
        <td><span class="row-num">${i + 1}</span></td>
        <td><span class="row-title">${m.title}</span></td>
        <td><span class="row-desc">${(m.description || '—').slice(0, 65)}${m.description?.length > 65 ? '…' : ''}</span></td>
        <td>${hasVideo
          ? `<a href="${m.video_url}" target="_blank" class="vid-link">
               <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
               Lihat
             </a>`
          : '<span class="no-video">—</span>'
        }</td>
        <td>
          <div class="action-btns">
            <button class="btn-icon edit" data-id="${m.id}" title="Edit">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z"/></svg>
            </button>
            <button class="btn-icon delete" data-id="${m.id}" title="Hapus">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
            </button>
          </div>
        </td>`;
      tbody.appendChild(tr);
    });

    // Attach events
    document.querySelectorAll('.edit').forEach(btn => btn.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLButtonElement).dataset.id;
      openModal(modules.find(x => x.id === id));
    }));
    document.querySelectorAll('.delete').forEach(btn => btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLButtonElement).dataset.id;
      if (confirm('Yakin ingin menghapus modul ini?')) {
        await supabase.from('modules').delete().eq('id', id);
        loadAdminData();
      }
    }));
  }

  function openModal(modul?: any) {
    modal.classList.remove('hidden');
    document.getElementById('modal-title')!.textContent = modul ? 'Edit Modul' : 'Tambah Modul';
    (document.getElementById('entry-id') as HTMLInputElement).value = modul?.id || '';
    (document.getElementById('title') as HTMLInputElement).value = modul?.title || '';
    (document.getElementById('description') as HTMLTextAreaElement).value = modul?.description || '';
    (document.getElementById('video_url') as HTMLInputElement).value = modul?.video_url || '';
  }

  function closeModal() {
    modal.classList.add('hidden');
    form.reset();
  }

  document.getElementById('btn-add-modul')!.addEventListener('click', () => openModal());
  document.getElementById('qa-tambah-modul')!.addEventListener('click', () => openModal());
  document.getElementById('btn-cancel')!.addEventListener('click', closeModal);
  document.getElementById('btn-modal-close')!.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  // Table search
  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    const filtered = modules.filter(m =>
      m.title?.toLowerCase().includes(q) || m.description?.toLowerCase().includes(q)
    );
    renderTable(filtered);
    document.getElementById('modul-count')!.textContent = `${filtered.length} modul`;
  });

  // Form submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('entry-id') as HTMLInputElement).value;
    const title = (document.getElementById('title') as HTMLInputElement).value;
    const description = (document.getElementById('description') as HTMLTextAreaElement).value;
    const video_url = (document.getElementById('video_url') as HTMLInputElement).value;

    const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
    btnSave.disabled = true;
    btnSave.textContent = 'Menyimpan...';

    if (id) {
      await supabase.from('modules').update({ title, description, video_url }).eq('id', id);
    } else {
      await supabase.from('modules').insert({ title, description, video_url });
    }

    btnSave.disabled = false;
    btnSave.innerHTML = `<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg> Simpan Modul`;
    closeModal();
    loadAdminData();
  });

  window.addEventListener('dashboard:ready', () => {
    loadAdminData();
  });
</script>
