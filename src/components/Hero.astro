---
---

<section id="hero">
  <!-- Animated background blobs -->
  <div class="hero-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="hero-container">
    <!-- LEFT: Copy -->
    <div class="hero-copy animate-fadeInLeft">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Platform E-Learning #1 di Indonesia
      </div>

      <h1 class="hero-headline">
        Belajar Lebih
        <span class="gradient-text" style="display:block;">Cerdas,</span>
        <span style="display:block;">Bukan Lebih Keras</span>
      </h1>

      <p class="hero-sub">
        BrainUp menghadirkan kuis interaktif, modul video berkualitas tinggi, dan sistem penilaian otomatis berbasis AI yang membantu kamu mencapai potensi belajar terbaik.
      </p>

      <div class="hero-actions">
        <a href="/register" id="hero-cta-primary" class="cta-main">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Mulai Belajar
          <svg class="arrow" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#cara-kerja" id="hero-cta-secondary" class="cta-secondary">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Lihat Demo
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <div class="stat-value gradient-text">50K+</div>
          <div class="stat-label">Pelajar Aktif</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <div class="stat-value gradient-text">1.2K+</div>
          <div class="stat-label">Kuis Tersedia</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <div class="stat-value gradient-text">98%</div>
          <div class="stat-label">Kepuasan User</div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Interactive Quiz Demo -->
    <div class="hero-demo animate-fadeInRight">
      <div class="demo-wrapper animate-float">
        <!-- Subtle corner glow -->
        <div class="quiz-glow"></div>

        <!-- Quiz card -->
        <div class="quiz-card" id="quiz-demo-card">
          <div class="quiz-header">
            <div class="quiz-brand">
              <div class="quiz-icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="#60a5fa">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26C17.81 13.47 19 11.38 19 9c0-3.87-3.13-7-7-7z"/>
                </svg>
              </div>
              <div>
                <div style="font-size:12px;font-weight:700;color:rgba(255,255,255,0.9);">Demo Kuis</div>
                <div style="font-size:10px;color:rgba(255,255,255,0.4);">Matematika Dasar</div>
              </div>
            </div>
            <div class="live-badge">
              <span class="live-dot"></span>
              LIVE
            </div>
          </div>

          <div class="quiz-progress-wrap">
            <div style="display:flex;justify-content:space-between;font-size:10px;color:rgba(255,255,255,0.4);margin-bottom:6px;">
              <span>Soal <span id="demo-current-q">1</span> dari 4</span>
              <span id="demo-score-display">Skor: 0</span>
            </div>
            <div class="progress-track">
              <div class="progress-fill" id="demo-progress-bar" style="width:25%"></div>
            </div>
          </div>

          <p class="quiz-question" id="demo-question">Berapa hasil dari 12 × 8?</p>

          <div id="demo-options" class="quiz-options"></div>
          <div id="demo-feedback" class="quiz-feedback hidden"></div>
          <button id="demo-next-btn" class="quiz-next-btn hidden">Soal Berikutnya →</button>

          <div id="demo-result" class="quiz-result hidden">
            <div style="font-size:52px;margin-bottom:12px;">🎉</div>
            <div class="gradient-text" style="font-size:20px;font-weight:900;margin-bottom:4px;" id="demo-final-score"></div>
            <div style="font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:20px;">Kuis selesai! Luar biasa!</div>
            <button id="demo-restart-btn" class="quiz-next-btn">Coba Lagi</button>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="float-badge float-badge-top">✓ +10 Poin!</div>
        <div class="float-badge float-badge-bottom">🔥 Streak 5 Hari</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <span>Gulir ke bawah</span>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 32px 80px;
    overflow: hidden;
  }

  /* Background */
  .hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }
  .blob-1 {
    width: 600px; height: 600px;
    top: -100px; left: -150px;
    background: radial-gradient(circle, rgba(37,99,235,0.35) 0%, transparent 70%);
    animation: drift 14s ease-in-out infinite;
  }
  .blob-2 {
    width: 500px; height: 500px;
    bottom: -80px; right: -100px;
    background: radial-gradient(circle, rgba(6,182,212,0.25) 0%, transparent 70%);
    animation: drift 18s ease-in-out infinite reverse;
  }
  .blob-3 {
    width: 400px; height: 400px;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(29,78,216,0.15) 0%, transparent 70%);
    animation: drift 10s ease-in-out infinite;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.06) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  /* Layout */
  .hero-container {
    max-width: 1280px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 1024px) {
    .hero-container { grid-template-columns: 1fr 1fr; }
  }

  /* Copy */
  .hero-copy { display: flex; flex-direction: column; gap: 28px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(37,99,235,0.12);
    border: 1px solid rgba(59,130,246,0.25);
    padding: 8px 16px;
    border-radius: 99px;
    font-size: 12px;
    font-weight: 700;
    color: #93c5fd;
    width: fit-content;
  }
  .badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74,222,128,0.8);
    animation: pulse-glow 2s ease-in-out infinite;
  }
  @keyframes badge-pulse {
    0%,100% { box-shadow: 0 0 6px rgba(74,222,128,0.7); }
    50%      { box-shadow: 0 0 14px rgba(74,222,128,1); }
  }

  .hero-headline {
    font-size: clamp(38px, 5vw, 64px);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -1.5px;
    color: #fff;
  }

  .hero-sub {
    font-size: 17px;
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
    max-width: 480px;
  }

  /* CTA */
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .cta-main {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    border-radius: 16px;
    font-size: 15px;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, #2563eb 0%, #0891b2 100%);
    box-shadow: 0 8px 30px rgba(37,99,235,0.5);
    transition: transform 0.25s, box-shadow 0.25s, filter 0.25s;
  }
  .cta-main:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(37,99,235,0.7);
    filter: brightness(1.1);
  }
  .cta-main .arrow { transition: transform 0.25s; }
  .cta-main:hover .arrow { transform: translateX(4px); }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 15px 28px;
    border-radius: 16px;
    font-size: 15px;
    font-weight: 700;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    transition: background 0.25s, color 0.25s, transform 0.25s;
    backdrop-filter: blur(12px);
  }
  .cta-secondary:hover {
    background: rgba(59,130,246,0.12);
    color: #fff;
    transform: translateY(-2px);
    border-color: rgba(59,130,246,0.35);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-value { font-size: 30px; font-weight: 900; }
  .stat-label { font-size: 11px; color: rgba(255,255,255,0.35); font-weight: 600; }
  .stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.07); }

  /* Demo wrapper */
  .hero-demo { display: flex; justify-content: center; }
  .demo-wrapper {
    position: relative;
    width: 100%;
    max-width: 400px;
  }

  /* Subtle glow behind card */
  .quiz-glow {
    position: absolute;
    inset: -20px;
    border-radius: 32px;
    background: radial-gradient(ellipse at center, rgba(37,99,235,0.3) 0%, transparent 70%);
    filter: blur(30px);
    z-index: 0;
    pointer-events: none;
  }

  /* Ring animation removed - was causing overflow */

  /* Quiz card */
  .quiz-card {
    background: rgba(8, 20, 50, 0.7);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 24px;
    padding: 28px;
    box-shadow:
      0 0 0 1px rgba(59,130,246,0.05),
      0 20px 60px rgba(0,0,0,0.5),
      0 0 80px rgba(37,99,235,0.12);
    position: relative;
    z-index: 1;
  }

  .quiz-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .quiz-brand { display: flex; align-items: center; gap: 10px; }
  .quiz-icon {
    width: 32px; height: 32px;
    border-radius: 9px;
    background: rgba(37,99,235,0.2);
    border: 1px solid rgba(59,130,246,0.3);
    display: flex; align-items: center; justify-content: center;
  }
  .live-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(4,13,30,0.6);
    border: 1px solid rgba(74,222,128,0.2);
    padding: 5px 12px;
    border-radius: 99px;
    font-size: 10px;
    font-weight: 800;
    color: #4ade80;
    letter-spacing: 1px;
  }
  .live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse-glow 1.5s ease-in-out infinite;
  }

  .quiz-progress-wrap { margin-bottom: 18px; }
  .progress-track {
    height: 5px;
    background: rgba(255,255,255,0.06);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #2563eb, #06b6d4);
    border-radius: 99px;
    transition: width 0.7s ease;
  }

  .quiz-question {
    font-size: 14px;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .quiz-options { display: flex; flex-direction: column; gap: 8px; }

  /* Options styled via JS */
  .quiz-option {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    color: rgba(255,255,255,0.7);
    font-size: 13px;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;
  }
  .quiz-option:hover:not(:disabled) {
    border-color: rgba(59,130,246,0.4);
    background: rgba(37,99,235,0.1);
    color: #fff;
    transform: translateX(3px);
  }
  .opt-letter {
    min-width: 24px; height: 24px;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    font-weight: 800;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
  }
  .quiz-option.correct {
    border-color: rgba(74,222,128,0.5) !important;
    background: rgba(74,222,128,0.08) !important;
    color: #86efac !important;
  }
  .quiz-option.correct .opt-letter {
    background: rgba(74,222,128,0.2) !important;
    border-color: rgba(74,222,128,0.6) !important;
    color: #86efac !important;
  }
  .quiz-option.wrong {
    border-color: rgba(248,113,113,0.5) !important;
    background: rgba(248,113,113,0.08) !important;
    color: #fca5a5 !important;
  }
  .quiz-option.wrong .opt-letter {
    background: rgba(248,113,113,0.2) !important;
    border-color: rgba(248,113,113,0.5) !important;
    color: #fca5a5 !important;
  }

  .quiz-feedback {
    margin-top: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 700;
    text-align: center;
  }
  .quiz-feedback.hidden { display: none; }
  .quiz-feedback.success {
    background: rgba(74,222,128,0.08);
    border: 1px solid rgba(74,222,128,0.25);
    color: #86efac;
  }
  .quiz-feedback.error {
    background: rgba(248,113,113,0.08);
    border: 1px solid rgba(248,113,113,0.25);
    color: #fca5a5;
  }

  .quiz-next-btn {
    display: block;
    width: 100%;
    margin-top: 12px;
    padding: 12px;
    border-radius: 12px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    border: none;
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(37,99,235,0.35);
  }
  .quiz-next-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,99,235,0.55); filter: brightness(1.1); }
  .quiz-next-btn.hidden { display: none; }

  .quiz-result { text-align: center; padding: 16px 0; }
  .quiz-result.hidden { display: none; }

  /* Float badges */
  .float-badge {
    position: absolute;
    background: rgba(8,20,50,0.85);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 12px;
    padding: 8px 14px;
    font-size: 11px;
    font-weight: 800;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    white-space: nowrap;
    z-index: 2;
  }
  .float-badge-top  { top: -18px; right: -18px; color: #86efac; border-color: rgba(74,222,128,0.25); }
  .float-badge-bottom { bottom: -18px; left: -18px; color: #93c5fd; }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.2);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    animation: float 3s ease-in-out infinite;
    z-index: 1;
  }
</style>

<script>
  const quizData = [
    { q: 'Berapa hasil dari 12 × 8?',         opts: ['86','96','106','76'],         ans: 1 },
    { q: 'Nilai dari √144 adalah?',            opts: ['10','14','12','16'],           ans: 2 },
    { q: 'Jika x + 5 = 17, maka x adalah?',  opts: ['10','13','12','11'],           ans: 2 },
    { q: 'Pecahan 3/4 setara dengan berapa?', opts: ['0.50','0.70','0.80','0.75'],  ans: 3 },
  ];

  let currentQ = 0, score = 0, answered = false;
  const qEl      = document.getElementById('demo-question')!;
  const optsEl   = document.getElementById('demo-options')!;
  const fbEl     = document.getElementById('demo-feedback')!;
  const nextBtn  = document.getElementById('demo-next-btn')!;
  const progBar  = document.getElementById('demo-progress-bar')!;
  const currQEl  = document.getElementById('demo-current-q')!;
  const scoreEl  = document.getElementById('demo-score-display')!;
  const resultEl = document.getElementById('demo-result')!;
  const finalEl  = document.getElementById('demo-final-score')!;
  const restBtn  = document.getElementById('demo-restart-btn')!;
  const qWrap    = qEl.parentElement!;

  function render() {
    answered = false;
    const d = quizData[currentQ];
    qEl.textContent = d.q;
    currQEl.textContent = String(currentQ + 1);
    progBar.style.width = `${((currentQ + 1) / quizData.length) * 100}%`;
    fbEl.className = 'quiz-feedback hidden';
    nextBtn.classList.add('hidden');
    optsEl.innerHTML = '';

    d.opts.forEach((o, i) => {
      const btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.innerHTML = `<span class="opt-letter">${['A','B','C','D'][i]}</span><span>${o}</span>`;
      btn.addEventListener('click', () => pick(i, btn, d.ans));
      optsEl.appendChild(btn);
    });
  }

  function pick(sel: number, _: HTMLButtonElement, ans: number) {
    if (answered) return;
    answered = true;
    const allBtns = optsEl.querySelectorAll<HTMLButtonElement>('.quiz-option');
    allBtns.forEach((b, i) => {
      b.disabled = true;
      if (i === ans) b.classList.add('correct');
      else if (i === sel && sel !== ans) b.classList.add('wrong');
    });
    if (sel === ans) {
      score += 25;
      scoreEl.textContent = `Skor: ${score}`;
      fbEl.textContent = '✅ Benar! Kerja bagus!';
      fbEl.className = 'quiz-feedback success';
    } else {
      fbEl.textContent = `❌ Belum tepat. Jawaban: ${['A','B','C','D'][ans]}`;
      fbEl.className = 'quiz-feedback error';
    }
    if (currentQ < quizData.length - 1) nextBtn.classList.remove('hidden');
    else setTimeout(showResult, 1400);
  }

  function showResult() {
    qWrap.style.display = 'none';
    optsEl.style.display = 'none';
    fbEl.classList.add('hidden');
    nextBtn.classList.add('hidden');
    resultEl.classList.remove('hidden');
    finalEl.textContent = `Nilai Akhir: ${score}/100`;
  }

  nextBtn.addEventListener('click', () => { currentQ++; render(); });
  restBtn.addEventListener('click', () => {
    currentQ = 0; score = 0; answered = false;
    scoreEl.textContent = 'Skor: 0';
    qWrap.style.display = '';
    optsEl.style.display = '';
    resultEl.classList.add('hidden');
    render();
  });

  render();
</script>
