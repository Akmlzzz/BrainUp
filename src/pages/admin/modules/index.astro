---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Kelola Modul" activePage="modules" role="admin">

  <!-- ══ PAGE HEADER ══ -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Manajemen Konten</h1>
      <p class="page-sub">Buat, edit, dan kelola seluruh modul pembelajaran serta kuis di platform BrainUp.</p>
    </div>
    <button class="btn-primary" id="btn-add-modul">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>
      Tambah Modul
    </button>
  </div>

  <!-- ══ FILTER BAR ══ -->
  <div class="filter-bar">
    <div class="search-box">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
      </svg>
      <input type="text" id="search-input" placeholder="Cari judul atau deskripsi modul..."/>
    </div>
    <div class="filter-right">
      <div class="select-wrap">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h14.25M3 9h9.75M3 13.5h5.25m5.25-.75L17.25 9m0 0L21 12.75M17.25 9v12"/>
        </svg>
        <select id="filter-status">
          <option value="">Semua Status</option>
          <option value="published">Published</option>
          <option value="draft">Draft</option>
        </select>
      </div>
      <div class="count-badge" id="modul-count">Memuat...</div>
    </div>
  </div>

  <!-- ══ TABLE PANEL ══ -->
  <div class="table-panel">
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th style="width:48px">#</th>
            <th>Modul</th>
            <th style="width:160px">Video</th>
            <th style="width:110px">Kuis</th>
            <th style="width:120px">Status</th>
            <th style="width:150px;text-align:center">Aksi</th>
          </tr>
        </thead>
        <tbody id="modules-body">
          <tr>
            <td colspan="6" class="loading-cell">
              <div class="spinner"></div>
              <span>Memuat data modul...</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ══ MODAL FORM ══ -->
  <div class="modal-overlay hidden" id="modal-form">
    <div class="modal-box">

      <!-- Modal Header -->
      <div class="modal-head">
        <div class="modal-head-icon" id="modal-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
        </div>
        <div class="modal-head-info">
          <h2 class="modal-title" id="modal-title">Tambah Modul Baru</h2>
          <p class="modal-sub">Isi informasi modul di bawah. Kolom bertanda <span class="req">*</span> wajib diisi.</p>
        </div>
        <button class="modal-close-btn" id="btn-modal-close" title="Tutup">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <form id="modul-form">
        <input type="hidden" id="entry-id"/>

        <!-- 2-Column Layout -->
        <div class="form-grid">

          <!-- LEFT: Info Dasar -->
          <div class="form-col">
            <div class="col-label">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
              </svg>
              Info Dasar
            </div>

            <div class="form-group">
              <label for="f-title">Judul Modul <span class="req">*</span></label>
              <input type="text" id="f-title" required placeholder="Contoh: Dasar-Dasar Aljabar Linear"/>
            </div>

            <div class="form-group">
              <label for="f-desc">Deskripsi Modul</label>
              <textarea id="f-desc" rows="5" placeholder="Jelaskan tujuan pembelajaran, materi yang dibahas, dan manfaat modul ini bagi pelajar..."></textarea>
            </div>

            <div class="form-group">
              <label for="f-status">Status Publikasi</label>
              <div class="select-wrap full-width">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <select id="f-status">
                  <option value="draft">📝 Draft — Belum dipublikasikan</option>
                  <option value="published">✅ Published — Tersedia untuk pelajar</option>
                </select>
              </div>
            </div>
          </div>

          <!-- RIGHT: Pengaturan Media & Kuis -->
          <div class="form-col">
            <div class="col-label">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/>
              </svg>
              Pengaturan Media
            </div>

            <div class="form-group">
              <label for="f-video">URL Video (YouTube / MP4)</label>
              <div class="input-icon-wrap">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/>
                </svg>
                <input type="url" id="f-video" placeholder="https://youtube.com/watch?v=..." class="with-icon"/>
              </div>
            </div>

            <div class="form-group">
              <label for="f-thumb">URL Thumbnail Gambar</label>
              <div class="input-icon-wrap">
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                </svg>
                <input type="url" id="f-thumb" placeholder="https://..." class="with-icon"/>
              </div>
            </div>

            <div class="col-label" style="margin-top:8px">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Pengaturan Kuis
            </div>

            <div class="quiz-info-box" id="quiz-info-box">
              <div class="quiz-info-icon">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>
                </svg>
              </div>
              <div>
                <p class="quiz-info-title" id="quiz-info-title">Simpan modul terlebih dahulu</p>
                <p class="quiz-info-sub" id="quiz-info-sub">Setelah modul tersimpan, tekan "Kelola Kuis" di tabel untuk menambah soal.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Toast notif -->
        <div class="form-toast hidden" id="form-toast"></div>

        <!-- Actions -->
        <div class="modal-actions">
          <button type="button" class="btn-ghost" id="btn-cancel">Batal</button>
          <button type="submit" class="btn-save" id="btn-save">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span id="btn-save-text">Simpan Modul</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ══ QUIZ MODAL (placeholder) ══ -->
  <div class="modal-overlay hidden" id="modal-quiz">
    <div class="modal-box" style="max-width:520px">
      <div class="modal-head">
        <div class="modal-head-icon" style="background:rgba(16,185,129,0.15);color:#34d399">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="modal-head-info">
          <h2 class="modal-title" id="quiz-modal-title">Kelola Kuis</h2>
          <p class="modal-sub" id="quiz-modal-sub">Daftar pertanyaan untuk modul ini.</p>
        </div>
        <button class="modal-close-btn" id="btn-quiz-close">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div id="quiz-body" style="padding:8px 0 4px">
        <div class="loading-cell"><div class="spinner"></div><span>Memuat kuis...</span></div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-ghost" id="btn-quiz-cancel">Tutup</button>
        <button type="button" class="btn-save" id="btn-add-question" style="background:linear-gradient(135deg,#059669,#10b981)">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          <span>Tambah Soal</span>
        </button>
      </div>
    </div>
  </div>

</DashboardLayout>

<!-- ══ STYLES ══ -->
<style>
  /* Page Header */
  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 24px; flex-wrap: wrap; gap: 14px;
  }
  .page-title { font-size: 24px; font-weight: 800; color: #f1f5f9; letter-spacing: -0.4px; margin-bottom: 5px; }
  .page-sub { font-size: 13.5px; color: rgba(255,255,255,0.38); max-width: 520px; line-height: 1.6; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 22px; border-radius: 12px;
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    color: #fff; font-size: 13.5px; font-weight: 700;
    border: none; cursor: pointer; font-family: 'Montserrat', sans-serif;
    box-shadow: 0 4px 18px rgba(99,102,241,0.40);
    transition: all 0.22s; white-space: nowrap; flex-shrink: 0;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(99,102,241,0.52); filter: brightness(1.08); }

  /* Filter Bar */
  .filter-bar {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 20px; flex-wrap: wrap;
  }
  .search-box {
    display: flex; align-items: center; gap: 10px;
    flex: 1; min-width: 200px;
    background: rgba(15,25,50,0.7);
    border: 1px solid rgba(99,102,241,0.18);
    border-radius: 12px; padding: 11px 16px;
    color: rgba(255,255,255,0.32);
    transition: border-color 0.2s;
  }
  .search-box:focus-within { border-color: rgba(99,102,241,0.45); }
  .search-box input {
    background: transparent; border: none; outline: none;
    color: #e8f4ff; font-size: 13.5px; font-family: 'Montserrat', sans-serif;
    flex: 1;
  }
  .search-box input::placeholder { color: rgba(255,255,255,0.22); }

  .filter-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

  .select-wrap {
    position: relative; display: flex; align-items: center; gap: 9px;
    background: rgba(15,25,50,0.7);
    border: 1px solid rgba(99,102,241,0.18);
    border-radius: 12px; padding: 10px 14px;
    color: rgba(255,255,255,0.38);
    transition: border-color 0.2s;
  }
  .select-wrap:focus-within { border-color: rgba(99,102,241,0.45); }
  .select-wrap select {
    background: transparent; border: none; outline: none;
    color: #e8f4ff; font-size: 13px; font-family: 'Montserrat', sans-serif;
    cursor: pointer; appearance: none; padding-right: 4px;
  }
  .select-wrap.full-width { width: 100%; }
  .select-wrap.full-width select { width: 100%; }
  .select-wrap select option { background: #0d1b35; color: #e8f4ff; }

  .count-badge {
    font-size: 12px; font-weight: 700; padding: 6px 14px;
    border-radius: 99px; white-space: nowrap;
    background: rgba(99,102,241,0.12);
    border: 1px solid rgba(99,102,241,0.25);
    color: #a5b4fc;
  }

  /* Table Panel */
  .table-panel {
    background: rgba(7,20,40,0.9);
    border: 1px solid rgba(99,102,241,0.10);
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 4px 30px rgba(0,0,0,0.3);
  }
  .table-wrap { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: separate; border-spacing: 0; text-align: left; }

  .data-table th {
    font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.28);
    text-transform: uppercase; letter-spacing: 0.8px;
    padding: 14px 22px;
    background: rgba(0,0,0,0.25);
    border-bottom: 1px solid rgba(99,102,241,0.08);
  }
  :global(.data-table td) {
    font-size: 13.5px; padding: 16px 22px;
    border-bottom: 1px solid rgba(99,102,241,0.06);
    color: #c8d9f0; vertical-align: middle;
  }
  :global(.data-table tbody tr:last-child td) { border-bottom: none; }
  :global(.data-table tbody tr) { transition: background 0.15s; }
  :global(.data-table tbody tr:hover td) { background: rgba(99,102,241,0.05); }

  /* Loading cell */
  .loading-cell {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; padding: 60px 24px !important;
    color: rgba(255,255,255,0.25) !important; font-size: 13px !important;
    text-align: center;
  }
  .spinner {
    width: 22px; height: 22px; border-radius: 50%;
    border: 2.5px solid rgba(99,102,241,0.15);
    border-top-color: #6366f1;
    animation: spin 0.8s linear infinite; flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Row styles (applied via JS) */
  :global(.row-num) { font-size: 12px; color: rgba(255,255,255,0.20); font-weight: 600; }
  :global(.row-main-title) { font-weight: 700; color: #f1f5f9 !important; font-size: 14px !important; display: block; margin-bottom: 3px; }
  :global(.row-desc-snip) { font-size: 12px; color: rgba(255,255,255,0.35) !important; display: block; max-width: 340px; line-height: 1.4; }

  /* Video badge */
  :global(.badge-video) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 8px;
    background: rgba(99,102,241,0.12);
    border: 1px solid rgba(99,102,241,0.25);
    color: #a5b4fc; font-size: 11.5px; font-weight: 600;
    text-decoration: none; transition: all 0.15s;
  }
  :global(.badge-video:hover) { background: rgba(99,102,241,0.22); color: #c7d2fe; }
  :global(.badge-no-video) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.25); font-size: 11.5px; font-weight: 600;
  }

  /* Quiz count badge */
  :global(.badge-quiz) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; border-radius: 8px;
    background: rgba(16,185,129,0.10);
    border: 1px solid rgba(16,185,129,0.22);
    color: #6ee7b7; font-size: 11.5px; font-weight: 700;
  }
  :global(.badge-quiz-zero) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.25); font-size: 11.5px; font-weight: 600;
  }

  /* Status badge */
  :global(.badge-published) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 8px;
    background: rgba(16,185,129,0.12);
    border: 1px solid rgba(16,185,129,0.25);
    color: #34d399; font-size: 11.5px; font-weight: 700;
  }
  :global(.badge-draft) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    color: rgba(255,255,255,0.42); font-size: 11.5px; font-weight: 700;
  }
  :global(.badge-dot) {
    width: 6px; height: 6px; border-radius: 50%; display: inline-block; flex-shrink: 0;
  }
  :global(.dot-green) { background: #34d399; box-shadow: 0 0 5px rgba(52,211,153,0.6); }
  :global(.dot-gray)  { background: rgba(255,255,255,0.3); }

  /* Action buttons */
  :global(.action-group) { display: flex; align-items: center; gap: 6px; justify-content: center; }
  :global(.btn-act) {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 6px 10px; border-radius: 8px;
    font-size: 11.5px; font-weight: 600;
    border: 1px solid; cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    transition: all 0.15s; white-space: nowrap;
  }
  :global(.btn-act svg) { width: 13px; height: 13px; flex-shrink: 0; }
  :global(.btn-edit) {
    background: rgba(99,102,241,0.10); border-color: rgba(99,102,241,0.22);
    color: #a5b4fc;
  }
  :global(.btn-edit:hover) { background: rgba(99,102,241,0.20); color: #c7d2fe; }
  :global(.btn-quiz-manage) {
    background: rgba(16,185,129,0.10); border-color: rgba(16,185,129,0.22);
    color: #6ee7b7;
  }
  :global(.btn-quiz-manage:hover) { background: rgba(16,185,129,0.20); color: #a7f3d0; }
  :global(.btn-delete) {
    background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.18);
    color: rgba(248,113,113,0.75);
  }
  :global(.btn-delete:hover) { background: rgba(239,68,68,0.15); color: #fca5a5; border-color: rgba(239,68,68,0.30); }

  /* Empty State */
  :global(.empty-state) {
    text-align: center; padding: 70px 24px !important;
    color: rgba(255,255,255,0.22) !important;
  }
  :global(.empty-state-icon) { font-size: 40px; display: block; margin-bottom: 14px; }
  :global(.empty-state-text) { font-size: 14px; display: block; font-weight: 600; color: rgba(255,255,255,0.30); margin-bottom: 4px; }
  :global(.empty-state-sub) { font-size: 12px; color: rgba(255,255,255,0.18); display: block; }

  /* ══ MODAL ══ */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(4,10,25,0.88);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    display: flex; align-items: center; justify-content: center;
    z-index: 900; padding: 20px;
  }
  .modal-overlay.hidden { display: none !important; }
  .modal-box {
    background: #060e22;
    border: 1px solid rgba(99,102,241,0.20);
    border-radius: 24px; padding: 0;
    width: 100%; max-width: 860px;
    max-height: 90vh; overflow-y: auto;
    box-shadow: 0 40px 100px rgba(0,0,0,0.70);
    animation: popIn 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes popIn {
    from { opacity: 0; transform: scale(0.96) translateY(20px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* Modal Head */
  .modal-head {
    display: flex; align-items: flex-start; gap: 16px;
    padding: 28px 28px 20px;
    border-bottom: 1px solid rgba(99,102,241,0.10);
  }
  .modal-head-icon {
    width: 50px; height: 50px; border-radius: 14px; flex-shrink: 0;
    background: rgba(99,102,241,0.15); color: #818cf8;
    display: flex; align-items: center; justify-content: center;
  }
  .modal-head-info { flex: 1; }
  .modal-title { font-size: 19px; font-weight: 800; color: #e8f4ff; margin-bottom: 3px; }
  .modal-sub { font-size: 12.5px; color: rgba(255,255,255,0.32); line-height: 1.5; }
  .req { color: #f87171; }
  .modal-close-btn {
    width: 34px; height: 34px; border-radius: 9px; flex-shrink: 0;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.38); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
  }
  .modal-close-btn:hover { background: rgba(239,68,68,0.10); color: #f87171; border-color: rgba(239,68,68,0.20); }

  /* Form Grid */
  .form-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 0; padding: 24px 28px 8px;
  }
  @media (max-width: 680px) { .form-grid { grid-template-columns: 1fr; } }
  .form-col { padding: 0 16px; }
  .form-col:first-child { padding-left: 0; border-right: 1px solid rgba(99,102,241,0.08); padding-right: 28px; }
  .form-col:last-child { padding-right: 0; padding-left: 28px; }

  .col-label {
    display: flex; align-items: center; gap: 7px;
    font-size: 10.5px; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.9px; color: rgba(255,255,255,0.28);
    margin-bottom: 18px; margin-top: 4px;
  }
  .col-label svg { color: #818cf8; }

  .form-group { margin-bottom: 18px; }
  label {
    display: block; font-size: 11px; font-weight: 700;
    color: rgba(255,255,255,0.38); margin-bottom: 8px;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  input, textarea, select {
    width: 100%; background: rgba(99,102,241,0.04);
    border: 1px solid rgba(99,102,241,0.14);
    border-radius: 11px; padding: 11px 14px;
    color: #e8f4ff; font-family: 'Montserrat', sans-serif; font-size: 13.5px;
    transition: border-color 0.2s, background 0.2s;
  }
  input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: rgba(99,102,241,0.50);
    background: rgba(99,102,241,0.07);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.10);
  }
  textarea { resize: vertical; min-height: 110px; }

  /* Input with icon */
  .input-icon-wrap { position: relative; display: flex; align-items: center; }
  .input-icon-wrap svg {
    position: absolute; left: 13px; color: rgba(255,255,255,0.25); flex-shrink: 0;
    pointer-events: none;
  }
  input.with-icon { padding-left: 38px; }

  /* Quiz info box */
  .quiz-info-box {
    display: flex; gap: 12px; align-items: flex-start;
    background: rgba(16,185,129,0.06);
    border: 1px solid rgba(16,185,129,0.15);
    border-radius: 12px; padding: 14px 16px;
    margin-top: 4px;
  }
  .quiz-info-icon {
    width: 36px; height: 36px; border-radius: 9px; flex-shrink: 0;
    background: rgba(16,185,129,0.12); color: #34d399;
    display: flex; align-items: center; justify-content: center;
  }
  .quiz-info-title { font-size: 13px; font-weight: 700; color: #e8f4ff; margin-bottom: 4px; }
  .quiz-info-sub { font-size: 11.5px; color: rgba(255,255,255,0.35); line-height: 1.5; }

  /* Form Toast */
  .form-toast {
    margin: 0 28px 4px; padding: 10px 16px; border-radius: 10px;
    font-size: 12.5px; font-weight: 600;
    display: flex; align-items: center; gap: 8px;
  }
  .form-toast.success {
    background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #34d399;
  }
  .form-toast.error {
    background: rgba(239,68,68,0.10); border: 1px solid rgba(239,68,68,0.22); color: #f87171;
  }
  .form-toast.hidden { display: none !important; }

  /* Modal Actions */
  .modal-actions {
    display: flex; justify-content: flex-end; gap: 10px;
    padding: 16px 28px 24px;
    border-top: 1px solid rgba(99,102,241,0.08);
    margin-top: 8px;
  }
  .btn-ghost {
    padding: 10px 20px; border-radius: 11px;
    background: rgba(99,102,241,0.05);
    border: 1px solid rgba(99,102,241,0.12);
    color: rgba(255,255,255,0.50); font-size: 13px; font-weight: 600;
    cursor: pointer; font-family: 'Montserrat', sans-serif;
    transition: all 0.15s;
  }
  .btn-ghost:hover { background: rgba(99,102,241,0.10); color: #e8f4ff; }
  .btn-save {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 22px; border-radius: 11px;
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    color: #fff; font-size: 13px; font-weight: 700;
    border: none; cursor: pointer; font-family: 'Montserrat', sans-serif;
    box-shadow: 0 4px 16px rgba(99,102,241,0.38);
    transition: all 0.2s;
  }
  .btn-save:hover { filter: brightness(1.1); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(99,102,241,0.48); }
  .btn-save:disabled { opacity: 0.6; cursor: not-allowed; transform: none; filter: none; }

  /* Quiz body items */
  :global(.quiz-item) {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px 28px;
    border-bottom: 1px solid rgba(99,102,241,0.07);
  }
  :global(.quiz-item:last-child) { border-bottom: none; }
  :global(.quiz-q-num) {
    width: 26px; height: 26px; border-radius: 7px; flex-shrink: 0;
    background: rgba(99,102,241,0.12); color: #a5b4fc;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
  }
  :global(.quiz-q-text) { font-size: 13px; color: #e2e8f0; line-height: 1.5; }
  :global(.quiz-q-count) { font-size: 11px; color: rgba(255,255,255,0.28); margin-top: 2px; }
  :global(.quiz-empty) {
    text-align: center; padding: 32px 24px;
    color: rgba(255,255,255,0.25); font-size: 13px;
  }
</style>

<script>
  import { supabase } from '../../../lib/supabase';

  // ── State ──────────────────────────────────────────────
  let allModules: any[] = [];
  let quizCounts: Record<string, number> = {};

  // ── DOM refs ──────────────────────────────────────────
  const tbody        = document.getElementById('modules-body')!;
  const modal        = document.getElementById('modal-form')!;
  const quizModal    = document.getElementById('modal-quiz')!;
  const form         = document.getElementById('modul-form') as HTMLFormElement;
  const searchInput  = document.getElementById('search-input') as HTMLInputElement;
  const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;
  const countBadge   = document.getElementById('modul-count')!;
  const toast        = document.getElementById('form-toast')!;

  // ── Load all modules + quiz counts ────────────────────
  async function loadData() {
    tbody.innerHTML = `<tr><td colspan="6" class="loading-cell"><div class="spinner"></div><span>Memuat data modul...</span></td></tr>`;

    const [modRes, quizRes] = await Promise.all([
      supabase.from('modules').select('*').order('created_at', { ascending: false }),
      supabase.from('quizzes').select('id, module_id, title')
    ]);

    allModules = modRes.data || [];

    // Build quiz count map: module_id -> count of questions
    const quizzes = quizRes.data || [];
    // Build counts per module (count quizzes linked)
    quizCounts = {};
    for (const q of quizzes) {
      if (!quizCounts[q.module_id]) quizCounts[q.module_id] = 0;
      quizCounts[q.module_id]++;
    }

    applyFilters();
  }

  // ── Filter + Render ───────────────────────────────────
  function applyFilters() {
    const q      = searchInput.value.toLowerCase().trim();
    const status = filterStatus.value;

    let filtered = allModules.filter(m => {
      const matchSearch = !q || m.title?.toLowerCase().includes(q) || m.description?.toLowerCase().includes(q);
      const matchStatus = !status || (m.status || 'draft') === status;
      return matchSearch && matchStatus;
    });

    countBadge.textContent = `${filtered.length} dari ${allModules.length} modul`;
    renderTable(filtered);
  }

  function renderTable(data: any[]) {
    if (data.length === 0) {
      tbody.innerHTML = `
        <tr><td colspan="6" class="empty-state">
          <span class="empty-state-icon">📭</span>
          <span class="empty-state-text">Tidak ada modul ditemukan</span>
          <span class="empty-state-sub">Coba ubah filter atau tambah modul baru.</span>
        </td></tr>`;
      return;
    }

    tbody.innerHTML = '';
    data.forEach((m, i) => {
      const tr      = document.createElement('tr');
      const hasVid  = m.video_url?.trim();
      const status  = m.status || 'draft';
      const qCount  = quizCounts[m.id] ?? 0;
      const descSnip = m.description
        ? m.description.slice(0, 72) + (m.description.length > 72 ? '…' : '')
        : '<em style="color:rgba(255,255,255,0.18)">Belum ada deskripsi</em>';

      tr.innerHTML = `
        <td><span class="row-num">0${i + 1}</span></td>
        <td>
          <span class="row-main-title">${escHtml(m.title)}</span>
          <span class="row-desc-snip">${descSnip}</span>
        </td>
        <td>
          ${hasVid
            ? `<a href="${escHtml(m.video_url)}" target="_blank" class="badge-video">
                 <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
                 Ada Video
               </a>`
            : `<span class="badge-no-video">
                 <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                 Tidak ada
               </span>`
          }
        </td>
        <td>
          ${qCount > 0
            ? `<span class="badge-quiz">
                 <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                 ${qCount} Kuis
               </span>`
            : `<span class="badge-quiz-zero">
                 <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/></svg>
                 Belum ada
               </span>`
          }
        </td>
        <td>
          ${status === 'published'
            ? `<span class="badge-published"><span class="badge-dot dot-green"></span>Published</span>`
            : `<span class="badge-draft"><span class="badge-dot dot-gray"></span>Draft</span>`
          }
        </td>
        <td>
          <div class="action-group">
            <button class="btn-act btn-edit" data-id="${m.id}" title="Edit Modul">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z"/></svg>
              Edit
            </button>
            <button class="btn-act btn-quiz-manage" data-id="${m.id}" data-title="${escHtml(m.title)}" title="Kelola Kuis">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Kuis
            </button>
            <button class="btn-act btn-delete" data-id="${m.id}" title="Hapus Modul">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
              Hapus
            </button>
          </div>
        </td>`;
      tbody.appendChild(tr);
    });

    attachRowEvents();
  }

  // ── Row Event Binding ─────────────────────────────────
  function attachRowEvents() {
    document.querySelectorAll<HTMLButtonElement>('.btn-edit').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id!;
        openModal(allModules.find(x => x.id === id));
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id!;
        const modul = allModules.find(x => x.id === id);
        if (!modul) return;
        if (!confirm(`Hapus modul "${modul.title}"? Tindakan ini tidak dapat diurungkan.`)) return;
        const { error } = await supabase.from('modules').delete().eq('id', id);
        if (!error) loadData();
        else alert('Gagal menghapus: ' + error.message);
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.btn-quiz-manage').forEach(btn => {
      btn.addEventListener('click', () => {
        const id    = btn.dataset.id!;
        const title = btn.dataset.title!;
        openQuizModal(id, title);
      });
    });
  }

  // ── Modal Open/Close ──────────────────────────────────
  function openModal(modul?: any) {
    document.getElementById('modal-title')!.textContent = modul ? 'Edit Modul' : 'Tambah Modul Baru';
    (document.getElementById('entry-id') as HTMLInputElement).value = modul?.id || '';
    (document.getElementById('f-title')  as HTMLInputElement).value = modul?.title || '';
    (document.getElementById('f-desc')   as HTMLTextAreaElement).value = modul?.description || '';
    (document.getElementById('f-video')  as HTMLInputElement).value = modul?.video_url || '';
    (document.getElementById('f-thumb')  as HTMLInputElement).value = modul?.thumbnail_url || '';
    (document.getElementById('f-status') as HTMLSelectElement).value = modul?.status || 'draft';

    const quizBox   = document.getElementById('quiz-info-box')!;
    const qTitle    = document.getElementById('quiz-info-title')!;
    const qSub      = document.getElementById('quiz-info-sub')!;
    if (modul?.id) {
      const cnt = quizCounts[modul.id] ?? 0;
      qTitle.textContent = cnt > 0 ? `${cnt} kuis terhubung` : 'Belum ada kuis';
      qSub.textContent   = cnt > 0 ? 'Klik "Kelola Kuis" di tabel untuk mengelola soal.' : 'Simpan modul lalu klik "Kelola Kuis" di tabel untuk menambah soal.';
    } else {
      qTitle.textContent = 'Simpan modul terlebih dahulu';
      qSub.textContent   = 'Setelah modul tersimpan, tekan "Kelola Kuis" di tabel untuk menambah soal.';
    }

    hideToast();
    modal.classList.remove('hidden');
    (document.getElementById('f-title') as HTMLInputElement).focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    form.reset();
    hideToast();
  }

  // ── Quiz Modal ────────────────────────────────────────
  async function openQuizModal(moduleId: string, moduleTitle: string) {
    document.getElementById('quiz-modal-title')!.textContent = 'Kelola Kuis';
    document.getElementById('quiz-modal-sub')!.textContent   = `Modul: ${moduleTitle}`;
    const qBody = document.getElementById('quiz-body')!;
    qBody.innerHTML = `<div class="loading-cell"><div class="spinner"></div><span>Memuat kuis...</span></div>`;
    quizModal.classList.remove('hidden');

    // Load quizzes for this module
    const { data: quizzes } = await supabase
      .from('quizzes')
      .select('id, title')
      .eq('module_id', moduleId)
      .order('created_at', { ascending: true });

    if (!quizzes || quizzes.length === 0) {
      qBody.innerHTML = `<div class="quiz-empty">📝 Belum ada kuis untuk modul ini.</div>`;
      return;
    }

    qBody.innerHTML = '';
    quizzes.forEach((q: any, idx: number) => {
      const item = document.createElement('div');
      item.className = 'quiz-item';
      item.innerHTML = `
        <div class="quiz-q-num">${idx + 1}</div>
        <div>
          <div class="quiz-q-text">${escHtml(q.title)}</div>
          <div class="quiz-q-count">ID: ${q.id.slice(0, 8)}…</div>
        </div>`;
      qBody.appendChild(item);
    });

    // Update quiz count
    quizCounts[moduleId] = quizzes.length;
  }

  function closeQuizModal() { quizModal.classList.add('hidden'); }

  // ── Toast ─────────────────────────────────────────────
  function showToast(msg: string, type: 'success'|'error') {
    toast.textContent = msg;
    toast.className = `form-toast ${type}`;
  }
  function hideToast() {
    toast.className = 'form-toast hidden';
    toast.textContent = '';
  }

  // ── Form Submit ───────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideToast();
    const id    = (document.getElementById('entry-id') as HTMLInputElement).value;
    const title = (document.getElementById('f-title')  as HTMLInputElement).value.trim();
    const desc  = (document.getElementById('f-desc')   as HTMLTextAreaElement).value.trim();
    const video = (document.getElementById('f-video')  as HTMLInputElement).value.trim();
    const thumb = (document.getElementById('f-thumb')  as HTMLInputElement).value.trim();
    const stat  = (document.getElementById('f-status') as HTMLSelectElement).value;

    const saveBtn  = document.getElementById('btn-save') as HTMLButtonElement;
    const saveTxt  = document.getElementById('btn-save-text')!;
    saveBtn.disabled = true;
    saveTxt.textContent = 'Menyimpan...';

    const payload = { title, description: desc || null, video_url: video || null, thumbnail_url: thumb || null, status: stat };

    let error: any = null;
    if (id) {
      const res = await supabase.from('modules').update(payload).eq('id', id);
      error = res.error;
    } else {
      const res = await supabase.from('modules').insert(payload);
      error = res.error;
    }

    saveBtn.disabled = false;
    saveTxt.textContent = 'Simpan Modul';

    if (error) {
      showToast('❌ Gagal menyimpan: ' + error.message, 'error');
      return;
    }

    showToast('✅ Modul berhasil disimpan!', 'success');
    setTimeout(() => { closeModal(); loadData(); }, 800);
  });

  // ── Event Listeners ───────────────────────────────────
  document.getElementById('btn-add-modul')!.addEventListener('click', () => openModal());
  document.getElementById('btn-modal-close')!.addEventListener('click', closeModal);
  document.getElementById('btn-cancel')!.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  document.getElementById('btn-quiz-close')!.addEventListener('click', closeQuizModal);
  document.getElementById('btn-quiz-cancel')!.addEventListener('click', closeQuizModal);
  quizModal.addEventListener('click', e => { if (e.target === quizModal) closeQuizModal(); });

  searchInput.addEventListener('input', applyFilters);
  filterStatus.addEventListener('change', applyFilters);

  // ── Util ──────────────────────────────────────────────
  function escHtml(str: string): string {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Init ──────────────────────────────────────────────
  window.addEventListener('dashboard:ready', loadData);
</script>
