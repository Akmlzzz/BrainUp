<section id="hero">

  <!-- ── Background ── -->
  <div class="hero-bg">
    <!-- Main gradient orb (center glow, like Astro.build) -->
    <div class="orb orb-main"></div>
    <div class="orb orb-left"></div>
    <div class="orb orb-right"></div>
    <!-- Subtle grid -->
    <div class="hero-grid"></div>
    <!-- Vignette top -->
    <div class="vignette-top"></div>
    <!-- Vignette bottom -->
    <div class="vignette-bottom"></div>
  </div>

  <!-- ── Content ── -->
  <div class="hero-content">

    <!-- Badge pill -->
    <a href="#fitur" class="hero-badge">
      <span class="badge-pill">BrainUp v1.0</span>
      <span class="badge-text">Tersedia Sekarang</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Headline -->
    <h1 class="hero-headline">
      Platform E-Quiz Cerdas<br class="hd-break"/>
      untuk Belajar<br class="hd-break-sm"/>
      <span class="headline-gradient">Lebih Efektif</span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-sub">
      Kuasai materi lebih cepat dengan kuis adaptif berbasis AI, modul video
      berkualitas tinggi, dan laporan progres real-time yang personal.
    </p>

    <!-- CTA Group -->
    <div class="hero-ctas">
      <a href="/register" id="hero-cta-primary" class="cta-primary">
        Mulai Belajar Gratis
      </a>
      <a href="#cara-kerja" id="hero-cta-secondary" class="cta-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        Lihat Demo
      </a>
    </div>

    <!-- Trust bar -->
    <div class="trust-bar">
      <p class="trust-label">Dipercaya oleh institusi pendidikan terkemuka</p>
      <div class="trust-logos">
        <span class="trust-logo">Universitas Indonesia</span>
        <span class="trust-sep">·</span>
        <span class="trust-logo">ITB</span>
        <span class="trust-sep">·</span>
        <span class="trust-logo">UGM</span>
        <span class="trust-sep">·</span>
        <span class="trust-logo">Binus</span>
        <span class="trust-sep">·</span>
        <span class="trust-logo">Telkom University</span>
        <span class="trust-sep">·</span>
        <span class="trust-logo">Ruangguru</span>
        <span class="trust-sep">·</span>
        <span class="trust-logo">Zenius</span>
      </div>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════
     HERO — Astro-inspired centered layout
     ═══════════════════════════════════════ */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 24px 100px;
    overflow: hidden;
    text-align: center;
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Main center orb — the big vivid glow */
  .orb-main {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(29, 78, 216, 0.75)  0%,
      rgba(37, 99, 235, 0.5)  25%,
      rgba(6, 182, 212, 0.25)  50%,
      transparent 72%
    );
    filter: blur(0px);
    animation: orb-breathe 8s ease-in-out infinite;
  }

  /* Side accent orbs */
  .orb-left {
    position: absolute;
    top: 20%;
    left: -10%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%);
    filter: blur(80px);
    animation: orb-drift-l 12s ease-in-out infinite;
  }
  .orb-right {
    position: absolute;
    top: 30%;
    right: -10%;
    width: 450px;
    height: 450px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6,182,212,0.15) 0%, transparent 70%);
    filter: blur(80px);
    animation: orb-drift-r 14s ease-in-out infinite;
  }

  /* Grid lines */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.07) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 0%, transparent 100%);
  }

  /* Dark vignette edges */
  .vignette-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 200px;
    background: linear-gradient(to bottom, #040d1e 0%, transparent 100%);
  }
  .vignette-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 300px;
    background: linear-gradient(to top, #040d1e 0%, transparent 100%);
  }

  /* Orb animations */
  @keyframes orb-breathe {
    0%, 100% { transform: translateX(-50%) scale(1);   opacity: 1; }
    50%       { transform: translateX(-50%) scale(1.08); opacity: 0.85; }
  }
  @keyframes orb-drift-l {
    0%, 100% { transform: translate(0, 0); }
    50%       { transform: translate(30px, -20px); }
  }
  @keyframes orb-drift-r {
    0%, 100% { transform: translate(0, 0); }
    50%       { transform: translate(-25px, 20px); }
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 820px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  /* ── Badge ── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 7px 7px 7px;
    border-radius: 99px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    text-decoration: none;
    font-size: 13px;
    color: rgba(255,255,255,0.8);
    font-weight: 600;
    transition: background 0.25s, border-color 0.25s, transform 0.25s;
    backdrop-filter: blur(12px);
  }
  .hero-badge:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(59,130,246,0.4);
    transform: translateY(-1px);
  }
  .badge-pill {
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 99px;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }
  .badge-text {
    padding-right: 2px;
    white-space: nowrap;
  }

  /* ── Headline ── */
  .hero-headline {
    font-size: clamp(36px, 6.5vw, 76px);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: -2.5px;
    color: #fff;
  }
  .hd-break    { display: none; }
  .hd-break-sm { display: none; }
  @media (min-width: 640px)  { .hd-break-sm { display: block; } }
  @media (min-width: 900px)  { .hd-break    { display: block; } }

  .headline-gradient {
    background: linear-gradient(135deg, #93c5fd 0%, #60a5fa 35%, #38bdf8 65%, #67e8f9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Subtitle ── */
  .hero-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
    max-width: 540px;
    letter-spacing: 0.1px;
  }

  /* ── CTA Group ── */
  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 6px;
  }

  /* Primary — white solid like Astro "Get Started" */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 99px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    color: #040d1e;
    background: #ffffff;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.8), 0 4px 24px rgba(255,255,255,0.2);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    white-space: nowrap;
    letter-spacing: -0.2px;
  }
  .cta-primary:hover {
    background: #e8f4ff;
    transform: translateY(-2px);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.9), 0 8px 32px rgba(255,255,255,0.3);
  }

  /* Secondary — dark pill (code-style like Astro "npm create astro") */
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    border-radius: 99px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.2s;
    white-space: nowrap;
    backdrop-filter: blur(8px);
  }
  .cta-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(59,130,246,0.35);
    color: #fff;
    transform: translateY(-1px);
  }

  /* ── Trust bar ── */
  .trust-bar {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .trust-label {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .trust-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px 4px;
    max-width: 760px;
  }

  .trust-logo {
    font-size: 14px;
    font-weight: 700;
    color: rgba(255,255,255,0.35);
    letter-spacing: -0.2px;
    padding: 4px 10px;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .trust-logo:hover { color: rgba(255,255,255,0.7); }

  .trust-sep {
    color: rgba(255,255,255,0.12);
    font-size: 16px;
    user-select: none;
  }

  /* fade-in on load */
  .hero-badge          { animation: fadeInUp 0.6s ease 0.1s both; }
  .hero-headline       { animation: fadeInUp 0.7s ease 0.2s both; }
  .hero-sub            { animation: fadeInUp 0.7s ease 0.35s both; }
  .hero-ctas           { animation: fadeInUp 0.7s ease 0.45s both; }
  .trust-bar           { animation: fadeInUp 0.7s ease 0.6s both; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
