---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard" activePage="dashboard" role="learner">

  <!-- ═══════════ PAGE HEADER ═══════════ -->
  <div class="ld-header">
    <div class="ld-header-text">
      <h1 class="ld-title">Selamat Datang Kembali! 👋</h1>
      <p class="ld-sub">Terus belajar dan raih prestasi terbaikmu hari ini.</p>
    </div>
    <a href="/dashboard" class="ld-btn-primary" id="btn-mulai">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347c-.75.412-1.667-.13-1.667-.986V5.653z"/>
      </svg>
      Lanjutkan Belajar
    </a>
  </div>

  <!-- ═══════════ STAT CARDS ═══════════ -->
  <div class="ld-stat-grid">

    <div class="ld-stat-card ld-card-blue">
      <div class="ld-stat-glow"></div>
      <div class="ld-stat-icon">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
        </svg>
      </div>
      <div class="ld-stat-body">
        <span class="ld-stat-label">Total Modul</span>
        <span class="ld-stat-value" id="stat-total-modul">—</span>
        <span class="ld-stat-note ld-note-blue">Tersedia untukmu</span>
      </div>
    </div>

    <div class="ld-stat-card ld-card-green">
      <div class="ld-stat-glow"></div>
      <div class="ld-stat-icon">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="ld-stat-body">
        <span class="ld-stat-label">Modul Selesai</span>
        <span class="ld-stat-value" id="stat-selesai">0</span>
        <span class="ld-stat-note ld-note-green">↑ Terus tingkatkan!</span>
      </div>
    </div>

    <div class="ld-stat-card ld-card-purple">
      <div class="ld-stat-glow"></div>
      <div class="ld-stat-icon">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
        </svg>
      </div>
      <div class="ld-stat-body">
        <span class="ld-stat-label">Total Poin</span>
        <span class="ld-stat-value" id="stat-poin">0</span>
        <span class="ld-stat-note ld-note-purple">pts terkumpul</span>
      </div>
    </div>

    <div class="ld-stat-card ld-card-orange">
      <div class="ld-stat-glow"></div>
      <div class="ld-stat-icon">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/>
        </svg>
      </div>
      <div class="ld-stat-body">
        <span class="ld-stat-label">Streak Belajar</span>
        <span class="ld-stat-value">🔥 1</span>
        <span class="ld-stat-note ld-note-orange">Hari berturut-turut</span>
      </div>
    </div>

  </div>

  <!-- ═══════════ MAIN CONTENT GRID ═══════════ -->
  <div class="ld-content-grid">

    <!-- LEFT PANEL: Progress -->
    <aside class="ld-panel ld-progress-panel">

      <!-- Ring header -->
      <div class="ld-panel-hd">
        <span class="ld-panel-title">Progres Belajarmu</span>
        <span class="ld-progress-badge" id="progress-pct-badge">0%</span>
      </div>

      <!-- Progress ring -->
      <div class="ld-ring-wrap">
        <svg class="ld-ring-svg" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="50" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="10"/>
          <circle id="progress-arc" cx="60" cy="60" r="50" fill="none"
            stroke="url(#ring-grad)" stroke-width="10"
            stroke-linecap="round"
            stroke-dasharray="314"
            stroke-dashoffset="314"
            transform="rotate(-90 60 60)"
            style="transition: stroke-dashoffset 1.2s cubic-bezier(0.4,0,0.2,1);"
          />
          <defs>
            <linearGradient id="ring-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#6366f1"/>
              <stop offset="100%" stop-color="#8b5cf6"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="ld-ring-inner">
          <span class="ld-ring-pct" id="ring-pct">0%</span>
          <span class="ld-ring-sub">Selesai</span>
        </div>
      </div>

      <!-- Mini stats -->
      <div class="ld-mini-stats">
        <div class="ld-mini-item">
          <span class="ld-mini-val" id="ms-selesai">0</span>
          <span class="ld-mini-lbl">Selesai</span>
        </div>
        <div class="ld-mini-divider"></div>
        <div class="ld-mini-item">
          <span class="ld-mini-val" id="ms-total">0</span>
          <span class="ld-mini-lbl">Total</span>
        </div>
        <div class="ld-mini-divider"></div>
        <div class="ld-mini-item">
          <span class="ld-mini-val" id="ms-sisa">0</span>
          <span class="ld-mini-lbl">Tersisa</span>
        </div>
      </div>

      <!-- Divider -->
      <div class="ld-panel-sep"></div>

      <!-- Quick links -->
      <div class="ld-quick-links">
        <p class="ld-quick-title">Aksi Cepat</p>
        <a href="/learner/quiz" class="ld-quick-link ld-ql-purple">
          <div class="ld-ql-icon">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <span class="ld-ql-label">Kerjakan Kuis</span>
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="ld-ql-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/dashboard" class="ld-quick-link ld-ql-blue">
          <div class="ld-ql-icon">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
            </svg>
          </div>
          <span class="ld-ql-label">Jelajahi Modul</span>
          <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="ld-ql-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Divider -->
      <div class="ld-panel-sep"></div>

      <!-- Recent Activity -->
      <div class="ld-activity">
        <p class="ld-act-title">Aktivitas Terakhir</p>
        <div class="ld-act-list" id="activity-list">
          <div class="ld-act-item">
            <div class="ld-act-dot ld-dot-blue">📖</div>
            <div class="ld-act-body">
              <span class="ld-act-text">Buka dashboard</span>
              <span class="ld-act-time">Baru saja</span>
            </div>
          </div>
          <div class="ld-act-item">
            <div class="ld-act-dot ld-dot-green">✅</div>
            <div class="ld-act-body">
              <span class="ld-act-text">Sesi login berhasil</span>
              <span class="ld-act-time">Hari ini</span>
            </div>
          </div>
        </div>
      </div>

    </aside>

    <!-- RIGHT PANEL: Modules -->
    <div class="ld-panel ld-modules-panel">

      <div class="ld-panel-hd">
        <span class="ld-panel-title">Modul Tersedia</span>
        <div class="ld-search-box">
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
          <input type="text" id="module-search" placeholder="Cari modul..." />
        </div>
      </div>

      <div class="ld-modules-grid" id="modules-grid">
        <div class="ld-loading">
          <div class="ld-spinner"></div>
          <p>Memuat modul belajar...</p>
        </div>
      </div>

    </div>

  </div>

</DashboardLayout>

<!-- ════════════════════════════════════════
     STYLES
════════════════════════════════════════ -->
<style>
  /* Page header */
  .ld-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .ld-title {
    font-size: 21px;
    font-weight: 800;
    color: #f0f8ff;
    letter-spacing: -0.3px;
    margin: 0 0 4px;
  }
  .ld-sub {
    font-size: 12.5px;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }
  .ld-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 12px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 18px rgba(37,99,235,0.35);
    transition: all 0.2s;
    font-family: 'Montserrat', sans-serif;
    white-space: nowrap;
  }
  .ld-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(37,99,235,0.45);
    filter: brightness(1.08);
  }

  /* ── Stat Cards ── */
  .ld-stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 1100px) { .ld-stat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .ld-stat-grid { grid-template-columns: 1fr; } }

  .ld-stat-card {
    position: relative;
    background: #071428;
    border: 1px solid rgba(59,130,246,0.08);
    border-radius: 18px;
    padding: 20px 20px 18px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    overflow: hidden;
    transition: transform 0.22s, box-shadow 0.22s;
  }
  .ld-stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 44px rgba(0,0,0,0.45);
  }
  .ld-stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 18px 18px 0 0;
  }
  .ld-card-blue::before   { background: linear-gradient(90deg, #2563eb, #06b6d4); }
  .ld-card-green::before  { background: linear-gradient(90deg, #10b981, #34d399); }
  .ld-card-purple::before { background: linear-gradient(90deg, #7c3aed, #6366f1); }
  .ld-card-orange::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }

  .ld-stat-glow {
    position: absolute;
    top: -40px; right: -40px;
    width: 100px; height: 100px;
    border-radius: 50%;
    filter: blur(30px);
    pointer-events: none;
    opacity: 0.5;
  }
  .ld-card-blue   .ld-stat-glow { background: rgba(37,99,235,0.18); }
  .ld-card-green  .ld-stat-glow { background: rgba(16,185,129,0.16); }
  .ld-card-purple .ld-stat-glow { background: rgba(124,58,237,0.16); }
  .ld-card-orange .ld-stat-glow { background: rgba(245,158,11,0.16); }

  .ld-stat-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    position: relative; z-index: 1;
  }
  .ld-card-blue   .ld-stat-icon { background: rgba(37,99,235,0.14);  color: #60a5fa; }
  .ld-card-green  .ld-stat-icon { background: rgba(16,185,129,0.14); color: #34d399; }
  .ld-card-purple .ld-stat-icon { background: rgba(99,102,241,0.14); color: #a78bfa; }
  .ld-card-orange .ld-stat-icon { background: rgba(245,158,11,0.14); color: #fbbf24; }

  .ld-stat-body {
    display: flex; flex-direction: column;
    gap: 3px; position: relative; z-index: 1;
  }
  .ld-stat-label {
    font-size: 10.5px; font-weight: 700;
    color: rgba(255,255,255,0.32);
    text-transform: uppercase; letter-spacing: 0.7px;
  }
  .ld-stat-value {
    font-size: 30px; font-weight: 900;
    color: #f0f8ff; letter-spacing: -0.5px; line-height: 1;
    margin: 5px 0 3px;
  }
  .ld-stat-note    { font-size: 11px; font-weight: 600; }
  .ld-note-blue    { color: #60a5fa; }
  .ld-note-green   { color: #34d399; }
  .ld-note-purple  { color: #a78bfa; }
  .ld-note-orange  { color: #fbbf24; }

  /* ── Content grid ── */
  .ld-content-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 20px;
    align-items: start;
  }
  @media (max-width: 1000px) { .ld-content-grid { grid-template-columns: 1fr; } }

  /* ── Panels ── */
  .ld-panel {
    background: #071428;
    border: 1px solid rgba(59,130,246,0.08);
    border-radius: 20px;
    overflow: hidden;
  }
  .ld-panel-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    gap: 12px; flex-wrap: wrap;
  }
  .ld-panel-title {
    font-size: 13px; font-weight: 700;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.02em;
  }
  .ld-progress-badge {
    font-size: 11px; font-weight: 800;
    padding: 3px 10px; border-radius: 99px;
    background: rgba(99,102,241,0.12);
    color: #a78bfa;
    border: 1px solid rgba(99,102,241,0.22);
  }
  .ld-panel-sep {
    height: 1px;
    background: rgba(255,255,255,0.04);
    margin: 0;
  }

  /* ── Progress ring ── */
  .ld-ring-wrap {
    display: flex; align-items: center; justify-content: center;
    padding: 28px 24px 20px;
    position: relative;
  }
  .ld-ring-svg { width: 154px; height: 154px; }
  .ld-ring-inner {
    position: absolute;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }
  .ld-ring-pct  { font-size: 28px; font-weight: 900; color: #e8f4ff; letter-spacing: -1px; }
  .ld-ring-sub  { font-size: 10px; color: rgba(255,255,255,0.28); font-weight: 600; margin-top: 3px; letter-spacing: 0.05em; text-transform: uppercase; }

  /* Mini stats */
  .ld-mini-stats {
    display: flex; align-items: center; justify-content: center;
    padding: 16px 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ld-mini-item  { text-align: center; flex: 1; }
  .ld-mini-val   { display: block; font-size: 20px; font-weight: 900; color: #e8f4ff; }
  .ld-mini-lbl   { font-size: 9.5px; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; }
  .ld-mini-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.06); margin: 0 4px; }

  /* Quick links */
  .ld-quick-links {
    padding: 18px 20px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .ld-quick-title {
    font-size: 10px; font-weight: 700;
    color: rgba(255,255,255,0.28);
    text-transform: uppercase; letter-spacing: 0.8px;
    margin: 0 0 4px;
  }
  .ld-quick-link {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: 12px;
    border: 1px solid transparent;
    text-decoration: none;
    font-size: 12.5px; font-weight: 600;
    transition: all 0.2s;
    cursor: pointer;
  }
  .ld-ql-icon {
    width: 30px; height: 30px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ld-ql-label { flex: 1; }
  .ld-ql-arrow { opacity: 0.4; transition: transform 0.2s, opacity 0.2s; }
  .ld-quick-link:hover .ld-ql-arrow { transform: translateX(3px); opacity: 0.9; }

  .ld-ql-purple {
    background: rgba(99,102,241,0.07);
    border-color: rgba(99,102,241,0.14);
    color: #c4b5fd;
  }
  .ld-ql-purple .ld-ql-icon { background: rgba(99,102,241,0.14); color: #a78bfa; }
  .ld-ql-purple:hover { background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.28); }

  .ld-ql-blue {
    background: rgba(37,99,235,0.07);
    border-color: rgba(37,99,235,0.14);
    color: #93c5fd;
  }
  .ld-ql-blue .ld-ql-icon { background: rgba(37,99,235,0.14); color: #60a5fa; }
  .ld-ql-blue:hover { background: rgba(37,99,235,0.12); border-color: rgba(37,99,235,0.28); }

  /* Activity */
  .ld-activity  { padding: 18px 20px 22px; }
  .ld-act-title {
    font-size: 10px; font-weight: 700;
    color: rgba(255,255,255,0.28);
    text-transform: uppercase; letter-spacing: 0.8px;
    margin: 0 0 14px;
  }
  .ld-act-list  { display: flex; flex-direction: column; gap: 12px; }
  .ld-act-item  { display: flex; align-items: center; gap: 12px; }
  .ld-act-dot {
    width: 32px; height: 32px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; flex-shrink: 0;
  }
  .ld-dot-blue   { background: rgba(59,130,246,0.10); }
  .ld-dot-green  { background: rgba(16,185,129,0.10); }
  .ld-act-body  { display: flex; flex-direction: column; gap: 1px; overflow: hidden; }
  .ld-act-text  { font-size: 12px; font-weight: 600; color: #cbd5e1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ld-act-time  { font-size: 10px; color: rgba(255,255,255,0.22); }

  /* Modules panel */
  .ld-search-box {
    display: flex; align-items: center; gap: 8px;
    background: rgba(59,130,246,0.05);
    border: 1px solid rgba(59,130,246,0.13);
    border-radius: 9px; padding: 7px 12px;
    color: rgba(255,255,255,0.28);
  }
  .ld-search-box input {
    background: transparent; border: none; outline: none;
    color: #e8f4ff; font-size: 12.5px;
    font-family: 'Montserrat', sans-serif;
    width: 160px;
  }
  .ld-search-box input::placeholder { color: rgba(255,255,255,0.2); }

  .ld-modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 14px;
    padding: 18px;
  }

  .ld-loading {
    grid-column: 1/-1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 12px; padding: 60px 20px;
    color: rgba(255,255,255,0.25);
    font-size: 13px;
  }
  .ld-spinner {
    width: 28px; height: 28px; border-radius: 50%;
    border: 2px solid rgba(99,102,241,0.15);
    border-top-color: #6366f1;
    animation: ld-spin 0.8s linear infinite;
  }
  @keyframes ld-spin { to { transform: rotate(360deg); } }

  /* Module cards (global – created by JS) */
  :global(.mod-card) {
    background: rgba(59,130,246,0.03);
    border: 1px solid rgba(59,130,246,0.09);
    border-radius: 16px;
    padding: 18px 16px;
    text-decoration: none;
    display: flex; flex-direction: column;
    gap: 12px;
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    cursor: pointer;
    position: relative; overflow: hidden;
  }
  :global(.mod-card::before) {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(37,99,235,0.07) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s;
  }
  :global(.mod-card:hover) {
    border-color: rgba(59,130,246,0.28);
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(29,78,216,0.18);
  }
  :global(.mod-card:hover::before) { opacity: 1; }

  :global(.mod-top) {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 8px;
  }
  :global(.mod-emoji) {
    font-size: 26px;
    width: 50px; height: 50px;
    background: rgba(37,99,235,0.10);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  :global(.mod-badge) {
    font-size: 10px; font-weight: 800;
    padding: 3px 9px; border-radius: 99px;
    text-transform: uppercase; letter-spacing: 0.4px;
    white-space: nowrap;
  }
  :global(.mod-badge.done) {
    background: rgba(16,185,129,0.09); color: #34d399;
    border: 1px solid rgba(16,185,129,0.18);
  }
  :global(.mod-badge.todo) {
    background: rgba(59,130,246,0.07); color: #93c5fd;
    border: 1px solid rgba(59,130,246,0.15);
  }
  :global(.mod-title) {
    font-size: 13.5px; font-weight: 700; color: #e8f4ff; line-height: 1.45;
  }
  :global(.mod-desc) {
    font-size: 11.5px; color: rgba(255,255,255,0.30);
    line-height: 1.6; flex: 1;
  }
  :global(.mod-footer) {
    display: flex; align-items: center; justify-content: flex-end;
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: auto;
  }
  :global(.mod-cta) {
    font-size: 12px; font-weight: 700; color: #60a5fa;
    display: flex; align-items: center; gap: 4px;
    transition: gap 0.2s;
  }
  :global(.mod-card:hover .mod-cta) { gap: 8px; }
</style>

<!-- ════════════════════════════════════════
     SCRIPT
════════════════════════════════════════ -->
<script>
  import { supabase } from '../../lib/supabase';

  const grid        = document.getElementById('modules-grid')!;
  const searchInput = document.getElementById('module-search') as HTMLInputElement;
  let allModules: any[] = [];

  const EMOJIS = ['🧮','📐','🔭','🧬','💡','📊','🗺️','🎨','⚙️','🌐','🔬','📚'];

  async function loadLearnerDashboard() {
    const { data, error } = await supabase
      .from('modules').select('*').order('created_at', { ascending: true });

    if (error) {
      grid.innerHTML = '<div class="ld-loading" style="color:#f87171;">Gagal memuat modul. Coba refresh.</div>';
      return;
    }

    allModules = data || [];

    const total   = allModules.length;
    const selesai = Math.floor(total * 0.3);
    const poin    = selesai * 100;
    const pct     = total > 0 ? Math.round((selesai / total) * 100) : 0;

    document.getElementById('stat-total-modul')!.textContent = String(total);
    document.getElementById('stat-selesai')!.textContent     = String(selesai);
    document.getElementById('stat-poin')!.textContent        = String(poin);

    const arc = document.getElementById('progress-arc')!;
    const circumference = 314;
    arc.style.strokeDashoffset = String(circumference - (pct / 100) * circumference);
    document.getElementById('ring-pct')!.textContent           = pct + '%';
    document.getElementById('progress-pct-badge')!.textContent = pct + '%';

    document.getElementById('ms-selesai')!.textContent = String(selesai);
    document.getElementById('ms-total')!.textContent   = String(total);
    document.getElementById('ms-sisa')!.textContent    = String(total - selesai);

    renderModules(allModules);
  }

  function renderModules(modules: any[]) {
    if (modules.length === 0) {
      grid.innerHTML = `
        <div class="ld-loading" style="grid-column:1/-1;">
          <span style="font-size:38px;">😴</span>
          <p>Belum ada modul yang tersedia.</p>
        </div>`;
      return;
    }

    grid.innerHTML = '';
    modules.forEach((m, i) => {
      const emoji  = EMOJIS[i % EMOJIS.length];
      const isDone = i % 3 === 0;
      const desc   = (m.description || 'Pelajari konsep penting dan kerjakan kuisnya.');
      const a = document.createElement('a');
      a.className = 'mod-card';
      a.href      = `/dashboard/module?id=${m.id}`;
      a.innerHTML = `
        <div class="mod-top">
          <div class="mod-emoji">${emoji}</div>
          <span class="mod-badge ${isDone ? 'done' : 'todo'}">${isDone ? '✓ Selesai' : 'Belum'}</span>
        </div>
        <div class="mod-title">${m.title}</div>
        <div class="mod-desc">${desc.slice(0, 72)}${desc.length > 72 ? '…' : ''}</div>
        <div class="mod-footer">
          <span class="mod-cta">
            Mulai
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </span>
        </div>`;
      grid.appendChild(a);
    });
  }

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    renderModules(allModules.filter(m =>
      m.title?.toLowerCase().includes(q) || m.description?.toLowerCase().includes(q)
    ));
  });

  window.addEventListener('dashboard:ready', () => loadLearnerDashboard());
</script>
