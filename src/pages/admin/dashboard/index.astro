---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Kelola Modul" activePage="modules" role="admin">
  <div class="action-header">
    <h2 class="title">Daftar Modul Pelajaran</h2>
    <button class="btn-primary" id="btn-add">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Tambah Modul
    </button>
  </div>

  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr>
          <th>Judul Modul</th>
          <th>Deskripsi</th>
          <th>URL Video</th>
          <th style="width:120px;text-align:right;">Aksi</th>
        </tr>
      </thead>
      <tbody id="modules-body">
        <tr><td colspan="4" style="text-align:center;color:rgba(255,255,255,0.4);border:none;">Memuat data...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Modal Dialog -->
  <div class="modal-overlay hidden" id="modal-form">
    <div class="modal-content">
      <h3 class="modal-title" id="modal-title">Tambah Modul</h3>
      <form id="modul-form">
        <input type="hidden" id="entry-id" />
        <div class="form-group">
          <label for="title">Judul Modul</label>
          <input type="text" id="title" required placeholder="Contoh: Operasi Aljabar" />
        </div>
        <div class="form-group">
          <label for="description">Deskripsi</label>
          <textarea id="description" rows="3" placeholder="Jelaskan isi singkat modul ini..."></textarea>
        </div>
        <div class="form-group">
          <label for="video_url">URL Video (YouTube / MP4)</label>
          <input type="url" id="video_url" placeholder="https://youtube.com/..." />
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-ghost" id="btn-cancel">Batal</button>
          <button type="submit" class="btn-primary" id="btn-save">Simpan Modul</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<style>
  .action-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .title { font-size: 20px; font-weight: 800; color: #fff; }
  .btn-primary {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: 12px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: #fff; font-size: 13px; font-weight: 700; border: none; cursor: pointer;
    box-shadow: 0 4px 14px rgba(37,99,235,0.3); transition: all 0.2s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(37,99,235,0.4); filter: brightness(1.1); }
  .btn-ghost {
    background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1);
    padding: 10px 18px; border-radius: 12px; font-size: 13px; font-weight: 600; cursor: pointer;
  }
  
  .table-container { background: rgba(8,20,50,0.6); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; }
  .data-table { width: 100%; border-collapse: collapse; text-align: left; }
  .data-table th { background: rgba(255,255,255,0.04); font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.6); text-transform: uppercase; padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .data-table td { font-size: 14px; padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,0.04); color: rgba(255,255,255,0.85); vertical-align: top; }
  .data-table tbody tr:hover { background: rgba(37,99,235,0.04); }
  
  .action-btns { display: flex; gap: 10px; justify-content: flex-end; }
  .btn-icon { background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.4); transition: color 0.2s; }
  .btn-icon:hover { color: #60a5fa; }
  .btn-icon.delete:hover { color: #ef4444; }

  /* Modal */
  .modal-overlay { position: fixed; inset: 0; background: rgba(4,13,30,0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 999; }
  .modal-overlay.hidden { display: none; }
  .modal-content { background: #081432; border: 1px solid rgba(59,130,246,0.2); border-radius: 24px; padding: 32px; width: 100%; max-width: 480px; box-shadow: 0 24px 80px rgba(0,0,0,0.5); }
  .modal-title { font-size: 20px; font-weight: 800; margin-bottom: 24px; }
  .form-group { margin-bottom: 16px; }
  label { display: block; font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
  input, textarea { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 12px 16px; color: #fff; font-family: inherit; font-size: 14px; }
  input:focus, textarea:focus { outline: none; border-color: #3b82f6; background: rgba(37,99,235,0.05); }
  .modal-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 28px; }
</style>

<script>
  import { supabase } from '../../../lib/supabase';

  let modules: any[] = [];
  const tbody = document.getElementById('modules-body')!;
  const modal = document.getElementById('modal-form')!;
  const form = document.getElementById('modul-form') as HTMLFormElement;

  async function loadModules() {
    const { data, error } = await supabase.from('modules').select('*').order('created_at', { ascending: false });
    if (error) {
      console.error(error);
      return;
    }
    modules = data || [];
    renderTable();
  }

  function renderTable() {
    if (modules.length === 0) {
      tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;color:rgba(255,255,255,0.4);">Belum ada modul yang ditambahkan.</td></tr>`;
      return;
    }

    tbody.innerHTML = '';
    modules.forEach(m => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td style="font-weight:700;">${m.title}</td>
        <td style="font-size:12px;color:rgba(255,255,255,0.5);max-width:200px;">${m.description?.slice(0,60) || ''}...</td>
        <td><a href="${m.video_url}" target="_blank" style="color:#60a5fa;font-size:12px;text-decoration:none;">Lihat Video</a></td>
        <td>
          <div class="action-btns">
            <button class="btn-icon edit" data-id="${m.id}" title="Edit">✏️</button>
            <button class="btn-icon delete" data-id="${m.id}" title="Hapus">🗑️</button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
    });

    // Attach events
    document.querySelectorAll('.edit').forEach(btn => btn.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLButtonElement).dataset.id;
      openModal(modules.find(x => x.id === id));
    }));
    document.querySelectorAll('.delete').forEach(btn => btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLButtonElement).dataset.id;
      if (confirm('Yakin ingin menghapus modul ini?')) {
        await supabase.from('modules').delete().eq('id', id);
        loadModules();
      }
    }));
  }

  function openModal(modul?: any) {
    modal.classList.remove('hidden');
    document.getElementById('modal-title')!.textContent = modul ? 'Edit Modul' : 'Tambah Modul';
    (document.getElementById('entry-id') as HTMLInputElement).value = modul?.id || '';
    (document.getElementById('title') as HTMLInputElement).value = modul?.title || '';
    (document.getElementById('description') as HTMLTextAreaElement).value = modul?.description || '';
    (document.getElementById('video_url') as HTMLInputElement).value = modul?.video_url || '';
  }

  function closeModal() {
    modal.classList.add('hidden');
    form.reset();
  }

  document.getElementById('btn-add')!.addEventListener('click', () => openModal());
  document.getElementById('btn-cancel')!.addEventListener('click', closeModal);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('entry-id') as HTMLInputElement).value;
    const title = (document.getElementById('title') as HTMLInputElement).value;
    const description = (document.getElementById('description') as HTMLTextAreaElement).value;
    const video_url = (document.getElementById('video_url') as HTMLInputElement).value;

    const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
    btnSave.disabled = true;
    btnSave.textContent = 'Menyimpan...';

    if (id) {
      await supabase.from('modules').update({ title, description, video_url }).eq('id', id);
    } else {
      await supabase.from('modules').insert({ title, description, video_url });
    }

    btnSave.disabled = false;
    btnSave.textContent = 'Simpan Modul';
    closeModal();
    loadModules();
  });

  // Init
  window.addEventListener('dashboard:ready', () => {
    loadModules();
  });
</script>
