---
const faqs = [
  { q: 'Apa itu BrainUp dan bagaimana cara kerjanya?', a: 'BrainUp adalah platform e-quiz dan e-learning interaktif yang memadukan video pembelajaran berkualitas tinggi dengan kuis adaptif berbasis AI. Pilih modul, tonton video, lalu kerjakan kuis. Sistem kami menganalisis jawabanmu dan memberikan rekomendasi materi yang perlu diperkuat.' },
  { q: 'Apakah bisa mencoba BrainUp secara gratis?', a: 'Tentu! Paket Free memungkinkan kamu mengakses 5 modul pilihan dan mengerjakan hingga 10 kuis per bulan tanpa biaya. Upgrade ke Pro atau Enterprise kapan saja untuk akses lebih lengkap.' },
  { q: 'Apakah sertifikat yang diberikan diakui secara resmi?', a: 'Sertifikat BrainUp dikeluarkan secara digital dan dapat diverifikasi melalui kode unik. Saat ini kami dalam proses akreditasi dengan lembaga pendidikan nasional, dan sudah diakui oleh 200+ perusahaan mitra.' },
  { q: 'Bagaimana sistem penilaian kuis di BrainUp bekerja?', a: 'Setiap soal dinilai otomatis setelah kamu mengirimkan jawaban. Smart Scoring AI memberikan umpan balik relevan, mengidentifikasi pola kesalahan, dan merekomendasikan materi review yang tepat sasaran.' },
  { q: 'Apakah konten video bisa diakses secara offline?', a: 'Fitur download video offline tersedia untuk pengguna Pro dan Enterprise. Nikmati video pelajaran tanpa koneksi internet melalui aplikasi mobile BrainUp (iOS & Android — segera hadir).' },
  { q: 'Bagaimana cara upgrade atau downgrade paket langganan?', a: 'Ubah paket kapan saja melalui menu "Pengaturan Akun" di dashboard. Perubahan berlaku di siklus penagihan berikutnya. Saat downgrade, kamu tetap menikmati fitur lama hingga masa berlaku berakhir.' },
  { q: 'Apakah ada paket khusus untuk sekolah atau institusi?', a: 'Ya! Paket Enterprise dirancang untuk sekolah, universitas, dan perusahaan besar. Kami menawarkan harga kustom, modul yang bisa dipersonalisasi, dan dashboard manajemen tim. Hubungi sales kami untuk penawaran.' },
];
---

<section id="faq">
  <div class="faq-bg">
    <div class="faq-blob"></div>
  </div>

  <div class="faq-container">
    <div class="section-header">
      <div class="section-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Ada Pertanyaan?
      </div>
      <h2 class="section-title">
        Pertanyaan yang<br/>
        <span class="gradient-text">Sering Ditanyakan</span>
      </h2>
      <p class="section-sub">Tidak menemukan jawaban? Tanyakan ke tim support kami yang siap membantu 24/7.</p>
    </div>

    <div class="faq-list">
      {faqs.map((faq, idx) => (
        <div class="faq-item" data-idx={idx}>
          <button class="faq-trigger" aria-expanded="false" id={`faq-btn-${idx}`}>
            <span class="faq-q">{faq.q}</span>
            <span class="faq-icon">
              <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>
          <div class="faq-body" id={`faq-body-${idx}`} aria-hidden="true">
            <p class="faq-a">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="faq-cta-box">
      <div style="font-size:44px;margin-bottom:14px;">💬</div>
      <h3 class="faq-cta-title">Masih ada pertanyaan lain?</h3>
      <p class="faq-cta-sub">Tim support kami siap membantu kapan saja, 24 jam sehari.</p>
      <a href="mailto:hello@brainup.id" id="faq-contact-btn" class="faq-cta-btn">
        Hubungi Support
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  #faq {
    position: relative;
    padding: 100px 32px;
    overflow: hidden;
  }
  .faq-bg { position: absolute; inset: 0; pointer-events: none; }
  .faq-blob {
    position: absolute;
    width: 500px; height: 500px;
    top: 20%; right: -50px;
    border-radius: 50%;
    filter: blur(130px);
    background: radial-gradient(circle, rgba(29,78,216,0.1) 0%, transparent 70%);
  }
  .faq-container { max-width: 800px; margin: 0 auto; position: relative; z-index: 1; }

  .faq-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 56px; }

  .faq-item {
    background: rgba(8,20,50,0.55);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px;
    overflow: hidden;
    transition: border-color 0.3s, background 0.3s;
  }
  .faq-item.is-open {
    border-color: rgba(59,130,246,0.25);
    background: rgba(37,99,235,0.06);
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 26px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
  }
  .faq-q {
    font-size: 15px;
    font-weight: 700;
    color: rgba(255,255,255,0.85);
    line-height: 1.45;
    transition: color 0.2s;
  }
  .faq-item.is-open .faq-q { color: #fff; }
  .faq-icon {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }
  .faq-item.is-open .faq-icon {
    background: rgba(37,99,235,0.15);
    border-color: rgba(59,130,246,0.35);
    color: #60a5fa;
  }
  .faq-chevron { transition: transform 0.35s ease; }
  .faq-item.is-open .faq-chevron { transform: rotate(180deg); }

  .faq-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
  }
  .faq-body.is-open {
    max-height: 400px;
    padding-bottom: 20px;
  }
  .faq-a {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.75;
    padding: 16px 26px 0 26px;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin: 0;
  }

  /* CTA box */
  .faq-cta-box {
    text-align: center;
    background: rgba(8,20,50,0.6);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(59,130,246,0.12);
    border-radius: 28px;
    padding: 48px 32px;
  }
  .faq-cta-title { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: 10px; }
  .faq-cta-sub   { font-size: 14px; color: rgba(255,255,255,0.4); margin-bottom: 28px; }
  .faq-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 14px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(37,99,235,0.4);
    transition: all 0.25s;
  }
  .faq-cta-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(37,99,235,0.6); filter: brightness(1.1); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const trigger = item.querySelector('.faq-trigger')!;
    const body    = item.querySelector<HTMLElement>('.faq-body')!;

    trigger.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');
      // Close all
      document.querySelectorAll<HTMLElement>('.faq-item').forEach(i => {
        i.classList.remove('is-open');
        i.querySelector<HTMLElement>('.faq-body')!.classList.remove('is-open');
        i.querySelector('.faq-trigger')!.setAttribute('aria-expanded','false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        body.classList.add('is-open');
        trigger.setAttribute('aria-expanded','true');
      }
    });
  });
</script>
