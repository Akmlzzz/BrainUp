---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Modul Belajar" activePage="modules" role="learner">
  <div class="header-intro">
    <h2 class="title">Modul Tersedia</h2>
    <p class="subtitle">Pilih modul untuk mulai belajar dan kumpulkan poin kuis.</p>
  </div>

  <div class="grid" id="modules-grid">
    <div class="loading">Memuat modul belajar terbaik untukmu...</div>
  </div>
</DashboardLayout>

<style>
  .header-intro { margin-bottom: 32px; }
  .title { font-size: 24px; font-weight: 800; color: #fff; margin-bottom: 6px; }
  .subtitle { font-size: 14px; color: rgba(255,255,255,0.5); }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }
  
  .loading { font-size: 13px; color: rgba(255,255,255,0.4); text-align: center; grid-column: 1 / -1; padding: 40px; }

  /* These styles apply universally to injected dynamic cards */
  :global(.modul-card) {
    background: rgba(8,20,50,0.6);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: all 0.3s;
    backdrop-filter: blur(12px);
  }
  :global(.modul-card:hover) {
    transform: translateY(-6px);
    border-color: rgba(59,130,246,0.4);
    box-shadow: 0 16px 40px rgba(37,99,235,0.15);
  }
  :global(.modul-icon) {
    width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(135deg, rgba(37,99,235,0.2), rgba(6,182,212,0.1));
    border: 1px solid rgba(59,130,246,0.25);
    display: flex; align-items: center; justify-content: center;
    color: #60a5fa; margin-bottom: 18px;
  }
  :global(.modul-title) { font-size: 16px; font-weight: 800; color: #fff; margin-bottom: 8px; line-height: 1.3}
  :global(.modul-desc) { font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.6; flex: 1; margin-bottom: 20px; }
  :global(.modul-btn) {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 13px; font-weight: 700; color: #60a5fa;
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';

  const grid = document.getElementById('modules-grid')!;

  async function loadLearnerModules() {
    const { data, error } = await supabase.from('modules').select('*').order('created_at', { ascending: true });
    
    if (error) {
      grid.innerHTML = '<div class="loading" style="color:#ef4444;">Gagal memuat modul.</div>';
      return;
    }

    if (!data || data.length === 0) {
      grid.innerHTML = '<div class="loading">Sabar ya, instruktur masih menyusun modul. ☕</div>';
      return;
    }

    grid.innerHTML = '';
    data.forEach(m => {
      const a = document.createElement('a');
      a.className = 'modul-card';
      a.href = `/dashboard/module?id=${m.id}`; // Using query param to avoid getStaticPaths need
      
      a.innerHTML = `
        <div class="modul-icon">
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="modul-title">${m.title}</h3>
        <p class="modul-desc">${m.description?.slice(0, 80) || 'Pelajari konsep fundamental dan uji kemampuanmu.'}...</p>
        <div class="modul-btn">
          Mulai Belajar <span>→</span>
        </div>
      `;
      grid.appendChild(a);
    });
  }

  // Load right when dashboard auth guard passes
  window.addEventListener('dashboard:ready', () => {
    loadLearnerModules();
  });
</script>
