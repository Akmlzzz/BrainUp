---
import '../../../styles/global.css';
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import QuizIsland from '../../../components/learner/QuizIsland';

// Mock data untuk title quiz
const quizTitle = 'Kuis Dasar Struktur Data & Arsitektur';
---

<DashboardLayout title={quizTitle} activePage="quiz" role="learner">
  <div class="quiz-page-wrap">
    <!-- Breadcrumb -->
    <div class="quiz-breadcrumb">
      <a href="/dashboard" class="bc-link">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Dashboard
      </a>
      <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="bc-sep">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="bc-current">Kuis Saya</span>
    </div>

    <!-- Island wrapper -->
    <QuizIsland title={quizTitle} client:only="react" />
  </div>
</DashboardLayout>

<style>
  .quiz-page-wrap {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .quiz-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
  }
  .bc-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.18s;
  }
  .bc-link:hover { color: #60a5fa; }
  .bc-sep { color: rgba(255,255,255,0.15); }
  .bc-current {
    color: #93c5fd;
    font-weight: 700;
  }
</style>
